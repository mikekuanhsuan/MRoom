BEGIN TRAN;

WITH DeleteCTE AS (
    SELECT 
        B.ID,
        ROW_NUMBER() OVER(
            PARTITION BY B.ID 
            ORDER BY 
                CASE WHEN EXISTS (
                    SELECT 1 FROM VERIFY..HRS_QuerySyntaxes V 
                    WHERE V.ID = B.ID AND ISNULL(V.qryId, '') = ISNULL(B.qryId, '')
                ) THEN 1 ELSE 2 END
        ) AS rn
    FROM BSADBTW..HRS_QuerySyntaxes B
)
-- 直接刪除排名第 2 筆以後的資料

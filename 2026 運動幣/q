
SELECT 
    CASE 
        WHEN V_ID.ID IS NULL THEN '保留 (孤兒資料 6906 筆)'
        WHEN V_Exact.ID IS NOT NULL THEN '保留 (與 VERIFY 完全一致的正牌資料 236442 筆)'
        ELSE '準備刪除 (多倒進去的衝突資料 236442 筆)'
    END AS DataGroup,
    COUNT(*) AS RecordCount
FROM BSADBTW..HRS_QuerySyntaxes B
LEFT JOIN VERIFY..HRS_QuerySyntaxes V_ID 
    ON B.ID = V_ID.ID
LEFT JOIN VERIFY..HRS_QuerySyntaxes V_Exact 
    ON B.ID = V_Exact.ID 
   AND ISNULL(B.qryId, '') = ISNULL(V_Exact.qryId, '')  -- 加上 qryId 精準比對
GROUP BY 
    CASE 
        WHEN V_ID.ID IS NULL THEN '保留 (孤兒資料 6906 筆)'
        WHEN V_Exact.ID IS NOT NULL THEN '保留 (與 VERIFY 完全一致的正牌資料 236442 筆)'
        ELSE '準備刪除 (多倒進去的衝突資料 236442 筆)'
    END;


DataGroup	RecordCount
保留 (孤兒資料 6906 筆)	6906
準備刪除 (多倒進去的衝突資料 236442 筆)	1386
保留 (與 VERIFY 完全一致的正牌資料 236442 筆)	471498


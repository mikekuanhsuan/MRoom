
SELECT 
    d.cif_key,
    c.CustomerNo,
    c.cust_nme  AS buffer_cust_nme,
    p.cust_nme  AS pb_cust_nme
FROM (
    SELECT SK_CUST_ID 
    FROM BANCS_SK_CUST_INFO 
    WHERE CUST_RE_NO_FLG = '1'

    EXCEPT

    SELECT SK_CUST_ID 
    FROM BANCS_SK_CUST_INFO 
    WHERE CUST_RE_NO_FLG IN ('2', '3')
) AS b   

JOIN Customer_Migrate_buffer c 
    ON c.CustomerNo = b.SK_CUST_ID   

JOIN BSA_SUB_CUST_FACT d 
    ON d.CustomerNo = c.CustomerNo

JOIN PB_CUSTOMER_FACT p
    ON d.cif_key = p.cif_key

WHERE 
      c.cust_nme <> p.cust_nme
   OR (c.cust_nme IS NULL AND p.cust_nme IS NOT NULL)
   OR (c.cust_nme IS NOT NULL AND p.cust_nme IS NULL);



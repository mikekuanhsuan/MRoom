WITH CheckCTE AS (
    SELECT 
        B.ID,
        -- 判斷這筆 ID 是否為孤兒
        CASE WHEN EXISTS (SELECT 1 FROM VERIFY..HRS_QuerySyntaxes V WHERE V.ID = B.ID) THEN 1 ELSE 0 END AS HasVerify,
        
        -- 強制給重複資料排號碼 (1號保留，2號以上刪除)
        ROW_NUMBER() OVER(
            PARTITION BY B.ID 
            ORDER BY 
                -- 優先度 1：能跟 VERIFY 的 qryId 完美對上的，給 1 分排最前面
                CASE WHEN EXISTS (
                    SELECT 1 FROM VERIFY..HRS_QuerySyntaxes V 
                    WHERE V.ID = B.ID AND ISNULL(V.qryId, '') = ISNULL(B.qryId, '')
                ) THEN 1 ELSE 2 END
        ) AS rn
    FROM BSADBTW..HRS_QuerySyntaxes B
)
SELECT 
    CASE 
        WHEN HasVerify = 0 THEN '保留 (孤兒資料 6906 筆)'
        WHEN rn = 1 THEN '保留 (與 VERIFY 最吻合的正牌資料 236442 筆)'
        ELSE '準備刪除 (多倒進去的衝突與完全重複資料 236442 筆)'
    END AS DataGroup,
    COUNT(*) AS RecordCount
FROM CheckCTE
GROUP BY 
    CASE 
        WHEN HasVerify = 0 THEN '保留 (孤兒資料 6906 筆)'
        WHEN rn = 1 THEN '保留 (與 VERIFY 最吻合的正牌資料 236442 筆)'
        ELSE '準備刪除 (多倒進去的衝突與完全重複資料 236442 筆)'
    END;






SELECT d.cif_key , d.CustomerNo
FROM (
    SELECT SK_CUST_ID 
    FROM BANCS_SK_CUST_INFO 
    WHERE CUST_RE_NO_FLG = '1'

    EXCEPT

    SELECT SK_CUST_ID 
    FROM BANCS_SK_CUST_INFO 
    WHERE CUST_RE_NO_FLG IN ('2', '3')
) AS b   

JOIN Customer_Migrate_buffer c 
    ON c.CustomerNo = b.SK_CUST_ID   

JOIN BSA_SUB_CUST_FACT d 
    ON d.CustomerNo = c.CustomerNo;



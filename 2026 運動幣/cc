SELECT DISTINCT
    b.CIF_KEY
FROM Cust_NP_Migrate_buffer b
JOIN CIF_Migrate_Mapping_TEMP m
    ON b.CIF_KEY = m.SOURCE_CIF_KEY
JOIN bsa_sub_cust_fact a
    ON m.NEW_CIF_KEY = a.CIF_KEY
JOIN BANCS_SK_CUST_INFO s
    ON a.CustomerNo = s.SK_CUST_ID
WHERE b.IsBearerShares = '1'
  AND ISNULL(s.CUST_RE_NO_FLG, '') <> '1'

INTERSECT

SELECT DISTINCT
    m.SOURCE_CIF_KEY
FROM bsa_sub_cust_fact a
JOIN CIF_Migrate_Mapping_TEMP m
    ON a.CIF_KEY = m.NEW_CIF_KEY
JOIN BANCS_SK_CUST_INFO s
    ON a.CustomerNo = s.SK_CUST_ID
WHERE a.Cust_With_Bearer_Shares = 'Y'
  AND ISNULL(s.CUST_RE_NO_FLG, '') <> '1';
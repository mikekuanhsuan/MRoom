🧩 Step 1：定義純 FLAG = 1 客戶集合

-- =============================================
-- Step 1：建立目標客戶集合
-- 條件：僅存在 CUST_RE_NO_FLG = '1'
-- 排除同時存在 '2' 或 '3' 的客戶
-- =============================================
WITH PureFlag1Cust AS (
    SELECT SK_CUST_ID
    FROM BANCS_SK_CUST_INFO
    GROUP BY SK_CUST_ID
    HAVING 
        MAX(CASE WHEN CUST_RE_NO_FLG IN ('2','3') THEN 1 ELSE 0 END) = 0
        AND MAX(CASE WHEN CUST_RE_NO_FLG = '1' THEN 1 ELSE 0 END) = 1
)

⸻

🧩 Step 2：確認 AML buffer 對應資料存在性

-- =============================================
-- Step 2：驗證 AML buffer 與主檔映射關係
-- 檢查客戶是否已成功對應至 AML 中介表與主檔
-- =============================================
SELECT 
    d.cif_key,
    d.CustomerNo
FROM PureFlag1Cust b
JOIN Customer_Migrate_buffer c
    ON c.CustomerNo = b.SK_CUST_ID
JOIN BSA_SUB_CUST_FACT d
    ON d.CustomerNo = c.CustomerNo;

⸻

🧩 Step 3：比對 buffer 與 PB 客戶名稱差異

-- =============================================
-- Step 3：比對客戶名稱一致性（資料異動檢查）
-- 用於偵測 buffer 與 PB 系統間是否存在名稱差異
-- =============================================
SELECT 
    d.cif_key,
    c.CustomerNo,
    c.cust_nme AS buffer_cust_name,
    p.cust_nme AS pb_cust_name
FROM PureFlag1Cust b
JOIN Customer_Migrate_buffer c
    ON c.CustomerNo = b.SK_CUST_ID
JOIN BSA_SUB_CUST_FACT d
    ON d.CustomerNo = c.CustomerNo
JOIN PB_CUSTOMER_FACT p
    ON p.cif_key = d.cif_key
WHERE 
    ISNULL(c.cust_nme, '') <> ISNULL(p.cust_nme, '');

⸻

🧩 Step 4：比對名稱一致資料（驗證一致性）

-- =============================================
-- Step 4：確認客戶名稱一致資料
-- 用於驗證 buffer 與 PB 系統資料一致性
-- =============================================
SELECT 
    d.cif_key,
    c.CustomerNo,
    c.cust_nme
FROM PureFlag1Cust b
JOIN Customer_Migrate_buffer c
    ON c.CustomerNo = b.SK_CUST_ID
JOIN BSA_SUB_CUST_FACT d
    ON d.CustomerNo = c.CustomerNo
JOIN PB_CUSTOMER_FACT p
    ON p.cif_key = d.cif_key
WHERE 
    ISNULL(c.cust_nme, '') = ISNULL(p.cust_nme, '');


✅ 完整驗證 SQL（真正可交付版）

⸻

① 定義 migration 母體（只用來圈人）

WITH PURE_1 AS (
    SELECT DISTINCT SK_CUST_ID
    FROM (
        SELECT SK_CUST_ID
        FROM BANCS_SK_CUST_INFO
        WHERE CUST_RE_NO_FLG = '1'
        EXCEPT
        SELECT SK_CUST_ID
        FROM BANCS_SK_CUST_INFO
        WHERE CUST_RE_NO_FLG IN ('2','3')
    ) t
)

⸻

② migration 成功進 PB 的數量

SELECT 
    COUNT(DISTINCT c.CustomerNo) AS MIGRATED_TO_PB
FROM PURE_1 t
JOIN Customer_Migrate_buffer c
    ON c.CustomerNo = t.SK_CUST_ID
JOIN BSA_SUB_CUST_FACT d
    ON d.CustomerNo = c.CustomerNo
JOIN PB_CUSTOMER_FACT p
    ON p.cif_key = d.cif_key;

⸻

③ ❗ missing（該進 PB 但沒進）

👉 這是最重要 KPI

SELECT 
    t.SK_CUST_ID AS CustomerNo
FROM PURE_1 t
JOIN Customer_Migrate_buffer c
    ON c.CustomerNo = t.SK_CUST_ID
JOIN BSA_SUB_CUST_FACT d
    ON d.CustomerNo = c.CustomerNo
LEFT JOIN PB_CUSTOMER_FACT p
    ON p.cif_key = d.cif_key
WHERE p.cif_key IS NULL;

⸻

④ ❗ extra（不該進 PB 但進了）

👉 這是 contamination check

SELECT 
    d.CustomerNo,
    p.cif_key
FROM PB_CUSTOMER_FACT p
JOIN BSA_SUB_CUST_FACT d
    ON d.cif_key = p.cif_key
LEFT JOIN PURE_1 t
    ON t.SK_CUST_ID = d.CustomerNo
WHERE t.SK_CUST_ID IS NULL;

⸻

⑤ name mismatch（你現在那 3508）

SELECT 
    d.cif_key,
    c.CustomerNo,
    c.cust_nme AS buffer_name,
    p.cust_nme AS pb_name
FROM PURE_1 t
JOIN Customer_Migrate_buffer c
    ON c.CustomerNo = t.SK_CUST_ID
JOIN BSA_SUB_CUST_FACT d
    ON d.CustomerNo = c.CustomerNo
JOIN PB_CUSTOMER_FACT p
    ON p.cif_key = d.cif_key
WHERE ISNULL(c.cust_nme,'#') <> ISNULL(p.cust_nme,'#');

⸻


SELECT DISTINCT
    b.CIF_KEY,
    b.CustomerNo
FROM Cust_NP_Migrate_buffer b
JOIN BANCS_SK_CUST_INFO s
    ON b.CustomerNo = s.SK_CUST_ID
WHERE b.IsBearerShares = '1'
  AND s.CUST_RE_NO_FLG = '1'


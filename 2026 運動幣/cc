;WITH Pure_Flag1 AS (
    SELECT SK_CUST_ID
    FROM BANCS_SK_CUST_INFO
    GROUP BY SK_CUST_ID
    HAVING 
        MAX(CASE WHEN CUST_RE_NO_FLG IN ('2','3') THEN 1 ELSE 0 END) = 0
        AND
        MAX(CASE WHEN CUST_RE_NO_FLG = '1' THEN 1 ELSE 0 END) = 1
),
Base_36 AS (
    SELECT 
        d.cif_key,
        c.CustomerNo,
        c.cust_nme AS buffer_cust_nme,
        p.cust_nme AS pb_cust_nme,
        c.OPEN_DTE AS buffer_open_dte,
        p.OPEN_DTE AS pb_open_dte
    FROM Pure_Flag1 b
    JOIN Customer_Migrate_buffer c 
        ON c.CustomerNo = b.SK_CUST_ID
    JOIN BSA_SUB_CUST_FACT d 
        ON d.CustomerNo = c.CustomerNo
    JOIN PB_CUSTOMER_FACT p
        ON d.cif_key = p.cif_key
    WHERE 
        ISNULL(c.cust_nme,'#') = ISNULL(p.cust_nme,'#')
)

-- 這裡改為撈出 36 筆完整明細
SELECT 
    -- 標記出你想找的 11 筆（日期不相同的會顯示 '日期不同'，相同的顯示 '日期相同'）
    CASE 
        WHEN ISNULL(CAST(buffer_open_dte AS DATE), '19000101') 
          <> ISNULL(CAST(pb_open_dte AS DATE), '19000101') 
        THEN '❌ 日期不同 (共11筆)' 
        ELSE '✅ 日期相同 (共25筆)' 
    END AS [比較結果],
    cif_key,
    CustomerNo,
    buffer_cust_nme,
    pb_cust_nme,
    buffer_open_dte,
    pb_open_dte
FROM Base_36
-- 透過排序，讓你想看的 11 筆「日期不同」的資料直接排在最上面
ORDER BY [比較結果] DESC, CustomerNo;
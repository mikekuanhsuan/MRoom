SELECT 
    spec_name as '姓名／名稱',
    TaxID as '稅號／統一編號',
    ent_num as '編號',
    b.GROUPDESCR as '名單群組名稱',
    ApprovedDate as '核准時間',
    remark as '備註'
FROM OFAC_SPEC a
LEFT JOIN lowrisklistgroups b 
    ON a.GROUPID = b.GROUPID
WHERE a.DIND = 'N' 
    AND ApprovedDate < '2026/04/01' -- 這樣才會包含到 3/31 全天的資料
    AND b.GROUPDESCR LIKE '%負面新聞%' -- 依照 E-mail 指定的群組篩選

                                UPDATE  T
                                SET     T.IsSARFiled = CASE M.ACTION
                                                         WHEN 'INSERT'
                                                         THEN S.IsSARFiled
                                                         ELSE T.IsSARFiled
                                                       END ,
                       -- HighRisk → highest wins
                                        T.HIGHRISK = CASE M.ACTION
                                                       WHEN 'INSERT'
                                                       THEN S.HIGHRISK
                                                       ELSE CASE
                                                              WHEN CASE S.HIGHRISK
                                                              WHEN 'L' THEN 1
                                                              WHEN 'M' THEN 2
                                                              WHEN 'H' THEN 3
                                                              ELSE 0
                                                              END > CASE T.HIGHRISK
                                                              WHEN 'L' THEN 1
                                                              WHEN 'M' THEN 2
                                                              WHEN 'H' THEN 3
                                                              ELSE 0
                                                              END
                                                              THEN S.HIGHRISK
                                                              ELSE T.HIGHRISK
                                                            END
                                                     END ,
                       -- RiskScore → follow chosen HighRisk
                                        T.RiskScore = CASE M.ACTION
                                                        WHEN 'INSERT'
                                                        THEN S.RiskScore
                                                        ELSE CASE
                                                              WHEN CASE S.HIGHRISK
                                                              WHEN 'L' THEN 1
                                                              WHEN 'M' THEN 2
                                                              WHEN 'H' THEN 3
                                                              ELSE 0
                                                              END > CASE T.HIGHRISK
                                                              WHEN 'L' THEN 1
                                                              WHEN 'M' THEN 2
                                                              WHEN 'H' THEN 3
                                                              ELSE 0
                                                              END
                                                              THEN S.RiskScore
                                                              ELSE T.RiskScore
                                                             END
                                                      END ,
                       -- IsComplexStructure → fill if NULL
                                        T.IsComplexStructure = CASE M.ACTION
                                                              WHEN 'INSERT'
                                                              THEN S.IsComplexStructure
                                                              ELSE 
																  CASE 
																		WHEN T.IsComplexStructure = 1 OR S.IsComplexStructure = 1 THEN 1
																		WHEN T.IsComplexStructure IS NULL AND S.IsComplexStructure IS NULL THEN NULL
																		ELSE 0
																  END 
															END,
                                        T.Warn_Restrict_Account = CASE 
																	WHEN T.Warn_Restrict_Account = 'Y' OR S.Warn_Restrict_Account = 1 THEN 'Y'
																	WHEN T.Warn_Restrict_Account IS NULL AND S.Warn_Restrict_Account IS NULL THEN NULL
																	ELSE 'N'
																END
                                OUTPUT  Inserted.CIF_KEY ,
                                        Deleted.IsComplexStructure ,
                                        Inserted.IsComplexStructure ,

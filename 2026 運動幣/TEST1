


SELECT COUNT(*)  HRS_QuerySyntaxes
FROM HRS_QuerySyntaxes A
INNER JOIN VERIFY..HRS_QuerySyntaxes B
    ON ISNULL(A.TemplateId,0) = ISNULL(B.TemplateId,0)
    AND ISNULL(A.GroupId,0) = ISNULL(B.GroupId,0)
    AND ISNULL(A.Parameter1,'') = ISNULL(B.Parameter1,'')
    AND ISNULL(A.Parameter2,'') = ISNULL(B.Parameter2,'')
    AND ISNULL(A.Parameter3,'') = ISNULL(B.Parameter3,'')
    AND ISNULL(A.Parameter4,'') = ISNULL(B.Parameter4,'')
    AND ISNULL(A.Parameter5,'') = ISNULL(B.Parameter5,'')
    AND ISNULL(A.Parameter6,'') = ISNULL(B.Parameter6,'')
    AND ISNULL(A.Parameter7,'') = ISNULL(B.Parameter7,'')
    AND ISNULL(A.Parameter8,'') = ISNULL(B.Parameter8,'')
    AND ISNULL(A.Parameter9,'') = ISNULL(B.Parameter9,'')
    AND ISNULL(A.Parameter10,'') = ISNULL(B.Parameter10,'')
    AND ISNULL(A.Score,0) = ISNULL(B.Score,0)
    AND ISNULL(A.CreatedDate,'19000101') = ISNULL(B.CreatedDate,'19000101')
    AND ISNULL(A.CreatedDate_UTC,'19000101') = ISNULL(B.CreatedDate_UTC,'19000101')
    AND ISNULL(A.LastModifiedDate,'19000101') = ISNULL(B.LastModifiedDate,'19000101')
    AND ISNULL(A.LastModifiedDate_UTC,'19000101') = ISNULL(B.LastModifiedDate_UTC,'19000101')
    AND ISNULL(A.CreatedBy,'') = ISNULL(B.CreatedBy,'')
    AND ISNULL(A.Enabled,0) = ISNULL(B.Enabled,0)
    AND ISNULL(A.Deleted,0) = ISNULL(B.Deleted,0)
    AND ISNULL(A.Repeatable,0) = ISNULL(B.Repeatable,0)
    AND ISNULL(A.Category,'') = ISNULL(B.Category,'')
    AND ISNULL(A.LastModifedBy,'') = ISNULL(B.LastModifedBy,'')
    AND ISNULL(A.qryId,0) = ISNULL(B.qryId,0);




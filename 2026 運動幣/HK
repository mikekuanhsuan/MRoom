2. 驗證明細（推薦交 QA）

這支會列出：

* TS_CUST_ID
* 來源最高風險
* BSA實際風險
* 是否一致

WITH JOINT_CUST AS
(
    SELECT TS_CUST_ID
    FROM BANCS_SK_CUST_INFO
    GROUP BY TS_CUST_ID
    HAVING COUNT(*) > 1
),
SRC AS
(
    SELECT
        s.TS_CUST_ID,
        MAX(
            CASE n.HIGHRISK
                WHEN 'H' THEN 3
                WHEN 'M' THEN 2
                WHEN 'L' THEN 1
                ELSE 0
            END
        ) AS SRC_RISK_NUM
    FROM JOINT_CUST j
    JOIN BANCS_SK_CUST_INFO s
        ON j.TS_CUST_ID = s.TS_CUST_ID
    JOIN Customer_Migrate_buffer c
        ON s.SK_CUST_ID = c.CustomerNo
    JOIN Cust_NP_Migrate_buffer n
        ON c.CIF_KEY = n.CIF_KEY
    GROUP BY s.TS_CUST_ID
),
TGT AS
(
    SELECT
        CustomerNo,
        CASE HIGHRISK
            WHEN 'H' THEN 3
            WHEN 'M' THEN 2
            WHEN 'L' THEN 1
            ELSE 0
        END AS TGT_RISK_NUM
    FROM BSA_SUB_CUST_FACT
)
SELECT
    s.TS_CUST_ID,
    CASE s.SRC_RISK_NUM
        WHEN 3 THEN 'H'
        WHEN 2 THEN 'M'
        WHEN 1 THEN 'L'
    END AS SOURCE_RISK,
    CASE t.TGT_RISK_NUM
        WHEN 3 THEN 'H'
        WHEN 2 THEN 'M'
        WHEN 1 THEN 'L'
    END AS TARGET_RISK,
    CASE
        WHEN s.SRC_RISK_NUM = t.TGT_RISK_NUM
        THEN 'PASS'
        ELSE 'FAIL'
    END AS RESULT
FROM SRC s
JOIN TGT t
    ON s.TS_CUST_ID = t.CustomerNo
ORDER BY RESULT DESC,
         s.TS_CUST_ID;


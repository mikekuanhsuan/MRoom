--LOAN CREATION
SELECT LI.LON_NO,LI.LON_CCY,LI.LON_AMT,LI.AML_INFO_SEQ
FROM HKWBS.LON_INFO LI;
--L/C CREATION
SELECT LC.LC_NO,LC.LC_NO_CCY,LC.LC_NO_AMT,LC.AML_INFO_SEQ
FROM HKWBS.IMP_LC LC;
--L/C AMENDMENT
SELECT LC.LC_NO,LC.LC_NO_CCY,LC.NEW_AMT,LC.AML_INFO_SEQ
FROM HKWBS.IMP_LC LC;
--SG/ED CREATION
SELECT SGED.SGED_NO,SGED.SGED_CCY,SGED.SGED_AMT
FROM HKWBS.IMP_SGED SGED;
--I/B CREATION
SELECT IB.IB_NO,IB.BILL_CCY,IB.BILL_AMT1,IB.AML_INFO_SEQ
FROM HKWBS.IMP_IB IB;
--I/C CREATION 
SELECT IC.IC_NO,IC.BILL_CCY,IC.BILL_AMT,IC.AML_INFO_SEQ
FROM HKWBS.IMP_IC IC;
--L/A CREATION/AMENDMENT
SELECT la.la_no,la.Lc_Ccy,LA.LC_AMT,LA.AML_INFO_SEQ
FROM HKWBS.Exp_La_Info la;
--L/T CREATION/amendment
SELECT LT.LT_NO,LT.LC_CCY,LT.LT_AMT
FROM HKWBS.EXP_LT_INFO LT;
--NEGO CREATION/AMENDMENT
SELECT ENI.NEGO_NO,ENI.BILL_CCY,ENI.BILL_AMT,ENI.AML_INFO_SEQ
FROM HKWBS.EXP_NEGO_INFO ENI;

--RENEGO CREATION
SELECT ERN.REF_NO,ERN.BILL_CCY,ERN.BILL_AMT,ERN.AML_INFO_SEQ
FROM HKWBS.EXP_RE_NEGO_INFO ERN;

--O/C CREATION/AMENDMENT
SELECT OC.OC_NO,OC.BILL_CCY,OC.BILL_AMT,OC.AML_INFO_SEQ
FROM HKWBS.EXP_OC_INFO OC;

--AML

SELECT A.AML_INFO_SEQ,B.CONTENT,B.COUNTRY_CONTENT,B.FLAG
--SELECT DISTINCT B.AML_TYPE
FROM HKWBS.AML_INFO A
INNER JOIN HKWBS.AML_DETAIL B ON A.AML_INFO_SEQ = B.AML_INFO_SEQ
WHERE B.AML_TYPE LIKE 'TAG44%';
--B.AML_TYHPE LIKE 'TAG44%'



select x.exp_action_item_seq,X.LT_NO,X.LC_CCY,X.LC_AMT,x.lt_amt,X.LT_AMT,X.LT_NEW_AMT,x.increase_lt_amt,x.decrease_lt_amt
from hkwbs.exp_LT_INFO_HS X
where x.lt_no = 'TSHK23LT00032900';
where x.lt_new_amt <> 0 and x.lt_new_amt <> x.lt_amt
order by 1;


最簡單驗證方式

直接找出寫錯的客戶：

SELECT
    bsa.CustomerNo,
    bsa.HIGHRISK AS BSA_RISK,
    MAX(
        CASE np.HIGHRISK
            WHEN 'H' THEN 3
            WHEN 'M' THEN 2
            WHEN 'L' THEN 1
        END
    ) AS NP_MAX_RISK
FROM BSA_SUB_CUST_FACT bsa
JOIN BANCS_SK_CUST_INFO sk
    ON bsa.CustomerNo = sk.TS_CUST_ID
JOIN Customer_Migrate_buffer cm
    ON sk.SK_CUST_ID = cm.CustomerNo
JOIN Cust_NP_Migrate_buffer np
    ON cm.CIF_KEY = np.CIF_KEY
GROUP BY
    bsa.CustomerNo,
    bsa.HIGHRISK
HAVING
    CASE bsa.HIGHRISK
        WHEN 'H' THEN 3
        WHEN 'M' THEN 2
        WHEN 'L' THEN 1
    END
    <>
    MAX(
        CASE np.HIGHRISK
            WHEN 'H' THEN 3
            WHEN 'M' THEN 2
            WHEN 'L' THEN 1
        END
    );


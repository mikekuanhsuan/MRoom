Ranked AS (
    SELECT *,
           ROW_NUMBER() OVER (
               PARTITION BY 
                   TemplateId,
                   GroupId,
                   Parameter1,
                   Parameter2,
                   Parameter3,
                   Parameter4,
                   Parameter5,
                   Parameter6,
                   Parameter7,
                   Parameter8,
                   Parameter9,
                   Parameter10,
                   Score,
                   Enabled,
                   Deleted,
                   Repeatable,

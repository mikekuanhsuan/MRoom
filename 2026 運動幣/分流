BEGIN TRAN;

DELETE B
FROM BSADBTW..HRS_QuerySyntaxes B
INNER JOIN VERIFY..HRS_QuerySyntaxes V
    ON ISNULL(B.ID,0) = ISNULL(V.ID,0)
   AND ISNULL(B.qryId,'') = ISNULL(V.qryId,'')
   AND ISNULL(B.TemplateId,0) = ISNULL(V.TemplateId,0)
   AND ISNULL(B.GroupId,0) = ISNULL(V.GroupId,0)
   AND ISNULL(B.Parameter1,'') = ISNULL(V.Parameter1,'')
   AND ISNULL(B.Parameter2,'') = ISNULL(V.Parameter2,'')
   AND ISNULL(B.Parameter3,'') = ISNULL(V.Parameter3,'')
   -- 其餘欄位全部補齊

SELECT @@ROWCOUNT AS DeletedCount;

-- COMMIT
-- ROLLBACK
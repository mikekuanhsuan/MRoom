        private void button1_Click(object sender, EventArgs e)
        {
            if (string.IsNullOrEmpty(txtFilePath))
            {
                MessageBox.Show($"找不到設定檔中的 TxtFilePath。{txtFilePath}");
                return;
            }

            if (!File.Exists(txtFilePath))
            {
                MessageBox.Show("找不到檔案: " + txtFilePath);
                return;
            }

            var lines = File.ReadAllLines(txtFilePath, Encoding.GetEncoding("big5"));
            var result = lines
                .Select(line => $"'{line.Trim().TrimStart('_')}'")
                .Where(s => s.Length > 2)
                .ToList();

            var outputLines = new List<string>();
            for (int i = 0; i < result.Count; i += 10)
            {
                outputLines.Add(string.Join(", ", result.Skip(i).Take(10)));
            }

            string outputString = string.Join(",\n", outputLines);


            if (string.IsNullOrEmpty(logFolder))
            {
                logFolder = Application.StartupPath; // 預設用執行檔目錄
            }
            if (!Directory.Exists(logFolder))
            {
                Directory.CreateDirectory(logFolder);
            }

            // 清空 logFolder 內容
            if (Directory.Exists(logFolder))
            {
                foreach (var file in Directory.GetFiles(logFolder))
                {
                    try { File.Delete(file); } catch { }
                }
                foreach (var dir in Directory.GetDirectories(logFolder))
                {
                    try { Directory.Delete(dir, true); } catch { }
                }
            }

            string logFileName = Path.Combine(
                logFolder,
                $"format_ids_log_{DateTime.Now:yyyyMMdd_HHmmss}.log"
            );
            File.WriteAllText(logFileName, outputString, Encoding.UTF8);


            MessageBox.Show("結果已儲存至: " + logFileName);
        }

        private void button2_Click(object sender, EventArgs e)
        {
            // 檢查 txtDataFile 是否有設定且檔案存在
            if (string.IsNullOrEmpty(txtDataFile) || !File.Exists(txtDataFile))
            {
                MessageBox.Show($"找不到 TXT 檔案路徑，請檢查 App.config 設定。{txtDataFile}");
                return;
            }
            // 若 outputFolder 未設定則預設為執行檔目錄
            if (string.IsNullOrEmpty(outputFolder))
                outputFolder = Application.StartupPath;
            // 若 outputFolder 不存在則建立資料夾
            if (!Directory.Exists(outputFolder))
                Directory.CreateDirectory(outputFolder);

            // 產生輸出檔案名稱（含時間戳記）
            string outputTxt = Path.Combine(outputFolder, $"SQL_條件_{DateTime.Now:yyyyMMdd_HHmmss}.log");

            // 讀取 txt 檔案（以 Big5 編碼）
            var lines = File.ReadAllLines(txtDataFile, Encoding.GetEncoding("big5"));
            var dt = new DataTable();
            // 建立 DataTable 欄位
            dt.Columns.Add("需求月份");
            dt.Columns.Add("供給月份");
            dt.Columns.Add("分配量", typeof(decimal));
            dt.Columns.Add("列標籤");

            // 逐行處理資料（跳過第一行標題）
            foreach (var line in lines.Skip(1))
            {
                if (string.IsNullOrWhiteSpace(line)) continue;
                var parts = line.Split('\t'); // 以 Tab 分隔
                if (parts.Length < 4) continue;
                var row = dt.NewRow();
                row["需求月份"] = parts[0].Trim();
                row["供給月份"] = parts[1].Trim();
                // 轉換分配量為 decimal，失敗則設為 0
                row["分配量"] = decimal.TryParse(parts[2], out var val) ? val : 0;
                // 列標籤去除前導底線
                row["列標籤"] = parts[3].Trim().TrimStart('_');
                dt.Rows.Add(row);
            }

            // 依「供給月份」與「需求月份」分組
            var groups = dt.AsEnumerable()
                .GroupBy(r => new { 供給月份 = r["供給月份"], 需求月份 = r["需求月份"] });

            var sb = new StringBuilder();
            sb.AppendLine("=== SQL 條件結果 ===");
            sb.AppendLine($"資料筆數: {dt.Rows.Count} 筆");
            sb.AppendLine($"產生時間: {DateTime.Now:yyyy-MM-dd HH:mm:ss}");
            sb.AppendLine(new string('=', 100));

            // 針對每個分組產生 SQL 條件摘要
            foreach (var g in groups)
            {
                // 依「列標籤」再分組並加總分配量
                var result = g.GroupBy(r => r["列標籤"])
                              .Select(grp => new { 列標籤 = grp.Key, 分配量 = grp.Sum(r => Convert.ToDecimal(r["分配量"])) })
                              .OrderBy(x => x.列標籤);

                sb.AppendLine();
                sb.AppendLine($"供給月份: {g.Key.供給月份}(新增) → 需求月份: {g.Key.需求月份}(新增)");
                sb.AppendLine($"總分配量: {result.Sum(x => x.分配量)}");
                sb.AppendLine();
                sb.AppendLine("完整 SQL 條件：");
                // 組合 SQL 條件（多個條件以 OR 連接）
                sb.AppendLine(string.Join(" OR\n", result.Select(x => $"BRNCH_NBR = '{x.列標籤}' AND CNT <= {x.分配量}")));
                sb.AppendLine();
                sb.AppendLine(new string('-', 100));
            }

            // 將結果寫入檔案（UTF-8 編碼）
            File.WriteAllText(outputTxt, sb.ToString(), Encoding.UTF8);

            // 顯示完成訊息與檔案路徑
            MessageBox.Show($"完成！\nLOG 檔案：{outputTxt}");
        }


        private void button3_Click(object sender, EventArgs e)
        {
            if (string.IsNullOrEmpty(outputFolder) || !Directory.Exists(outputFolder))
            {
                MessageBox.Show("找不到 OutputFolder，請檢查 App.config 設定。");
                return;
            }

            // 取得 Low_OutputFolder 路徑，並找最新的 format_ids_log_*.log
            string lowOutputFolder = ConfigurationManager.AppSettings["Low_OutputFolder"];
            if (string.IsNullOrEmpty(lowOutputFolder) || !Directory.Exists(lowOutputFolder))
            {
                MessageBox.Show("找不到 Low_OutputFolder，請檢查 App.config 設定。");
                return;
            }
            var formatLogFiles = Directory.GetFiles(lowOutputFolder, "format_ids_log_*.log");
            if (formatLogFiles.Length == 0)
            {
                MessageBox.Show("找不到 format_ids_log_*.log 檔案。");
                return;
            }
            string latestFormatLog = formatLogFiles.OrderByDescending(File.GetLastWriteTime).First();
            string branchInList = File.ReadAllText(latestFormatLog, Encoding.UTF8)
                .Replace("\r", "")
                .Replace("\n", "")
                .Trim();

            // 找最新的 SQL_條件_*.log
            var txtFiles = Directory.GetFiles(outputFolder, "SQL_條件_*.log");
            if (txtFiles.Length == 0)
            {
                MessageBox.Show($"找不到 SQL_條件_*.log 檔案。{txtFiles}");
                return;
            }
            string latestTxt = txtFiles.OrderByDescending(File.GetLastWriteTime).First();

            // 讀取 SQL 條件 txt
            string content = File.ReadAllText(latestTxt, Encoding.UTF8);
            var blocks = Regex.Split(content, "-{10,}");
            var allSql = new List<string>();
            var summaryList = new List<(string supply, string demand, decimal total, int count)>();

            foreach (var block in blocks)
            {
                var m = Regex.Match(block, @"供給月份:\s*(\d{6})[^\d]+需求月份:\s*(\d{6})");
                if (!m.Success) continue;
                string supply = m.Groups[1].Value;
                string demand = m.Groups[2].Value;

                // 取總分配量
                var totalMatch = Regex.Match(block, @"總分配量:\s*([\d\.]+)");
                decimal total = totalMatch.Success ? decimal.Parse(totalMatch.Groups[1].Value) : 0;

                // 取筆數
                var condMatch = Regex.Match(block, @"完整 SQL 條件：\s*([\s\S]+)");
                int count = 0;
                if (condMatch.Success)
                {
                    count = Regex.Matches(condMatch.Groups[1].Value, @"BRNCH_NBR\s*=").Count;
                }
                summaryList.Add((supply, demand, total, count));

                if (!condMatch.Success) continue;
                string branchLimit = condMatch.Groups[1].Value.Trim();

                // 產生 nextcheck
                string nextcheck = ConfigurationManager.AppSettings[$"NextCheck_{demand}"];
                if (string.IsNullOrEmpty(nextcheck))
                    nextcheck = "YYYYMMDD";

                // 依勾選狀態決定 HIGHRISK 條件
                string highRiskValue = checkBoxH.Checked ? "H" : (checkBoxM.Checked ? "M" : (checkBoxRisk.Checked ? "L" : ""));
                if (string.IsNullOrEmpty(highRiskValue))
                {
                    MessageBox.Show("請至少勾選一個風險模式（低/中/高）");
                    return;
                }

                // 組 SQL
                var sql = $@"
            -- =============================================
            -- 集中處理 - {(highRiskValue == "H" ? "高風險" : (highRiskValue == "M" ? "中風險" : "低風險"))}客戶 ({supply} 供給 → {demand} 需求)
            -- =============================================
            INSERT INTO @CustData
            SELECT CustomerNo, '{nextcheck}'
            FROM (
                SELECT 
                    A.CustomerNo,
                    D.BRNCH_NBR,
                    DENSE_RANK() OVER (PARTITION BY D.BRNCH_NBR ORDER BY A.CIF_KEY) AS CNT
                FROM (
                    SELECT CIF_KEY, CustomerNo 
                    FROM BSADBTW..BSA_SUB_CUST_FACT WITH (NOLOCK)
                    WHERE HIGHRISK = '{highRiskValue}'
                ) A

                INNER JOIN BSADBTW..PB_CUSTOMER_FACT D WITH (NOLOCK)
                    ON A.CIF_KEY = D.CIF_KEY 
                AND D.BRNCH_NBR IN ({branchInList})
                AND D.RecordStatus = 'O'
                AND D.Customer_Segment <> 'NCR'

                INNER JOIN BSADBTW..EDD_ReviewSchedule B WITH (NOLOCK)
                    ON A.CIF_KEY = B.CIFKey 
                AND B.Status = 'P'
                AND B.ReviewDt >= '{supply}01 00:00:00.000'
                AND B.ReviewDt <= '{supply}{DateTime.DaysInMonth(int.Parse(supply.Substring(0, 4)), int.Parse(supply.Substring(4, 2)))} 23:59:59.999'

                LEFT JOIN (
                    SELECT CIF_KEY 
                    FROM BSADBTW..HRS_CUST_RISK_MGMT WITH (NOLOCK)
                    WHERE STATUS <> '3'
                ) C ON A.CIF_KEY = C.CIF_KEY

                WHERE C.CIF_KEY IS NULL
            ) T

            WHERE 
            {branchLimit}

            ";
                allSql.Add(sql);
            }

            if (allSql.Count > 0)
            {
                string baseName = Path.GetFileNameWithoutExtension(latestTxt);
                string outFile = Path.Combine(outputFolder, $"Review_LowRisk_Combined_{baseName}.sql");
                File.WriteAllText(outFile, string.Join("\n", allSql), Encoding.UTF8);

                // 輸出 summary table（排序）
                var sb = new StringBuilder();
                sb.AppendLine("供給月份\t→ 需求月份\t總分配量\t筆數");
                foreach (var item in summaryList
                    .OrderBy(x => x.supply)
                    .ThenBy(x => x.demand))
                {
                    sb.AppendLine($"供給月份: {item.supply}(新增) → 需求月份: {item.demand}(新增)\t總分配量: {item.total}\t筆數: {item.count}");
                }
                string summaryFile = Path.Combine(outputFolder, $"Review_LowRisk_Summary_{baseName}.log");
                File.WriteAllText(summaryFile, sb.ToString(), Encoding.UTF8);

                MessageBox.Show($"所有 SQL 已合併並儲存至檔案:\n{outFile}\n\n統計表已輸出:\n{summaryFile}");
            }
            else
            {
                MessageBox.Show("沒有產生任何 SQL 程式碼。");
            }
        }


SELECT 
    TemplateId,
    GroupId,
    Parameter1,
    Parameter2,
    Parameter3,
    Parameter4,
    Parameter5,
    Parameter6,
    Parameter7,
    Parameter8,
    Parameter9,
    Parameter10,
    Score,
    CreatedDate,
    CreatedDate_UTC,
    LastModifiedDate,
    LastModifiedDate_UTC,
    CreatedBy,
    Enabled,
    Deleted,
    Repeatable,
    Category,
    LastModifedBy,
    qryId,
    COUNT(*) AS CNT
FROM HRS_QuerySyntaxes
GROUP BY
    TemplateId,
    GroupId,
    Parameter1,
    Parameter2,
    Parameter3,
    Parameter4,
    Parameter5,
    Parameter6,
    Parameter7,
    Parameter8,
    Parameter9,
    Parameter10,
    Score,
    CreatedDate,
    CreatedDate_UTC,
    LastModifiedDate,
    LastModifiedDate_UTC,
    CreatedBy,
    Enabled,
    Deleted,
    Repeatable,
    Category,
    LastModifedBy,
    qryId
HAVING COUNT(*) > 1;






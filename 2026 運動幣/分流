        private void LoadRiskLevelSettings(bool isLowRisk, bool isMiddleRisk, bool isHighRisk)
        {
            if (!isLowRisk && !isMiddleRisk && !isHighRisk)
            {
                MessageBox.Show("請至少勾選一個風險模式（低/中/高）", "提示", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }

            string prefix = isHighRisk ? "High_" : (isMiddleRisk ? "Medium_" : "Low_");


            txtFilePath = ConfigurationManager.AppSettings[$"{prefix}TxtFilePath"];
            logFolder = ConfigurationManager.AppSettings[$"{prefix}LogFolder"];
            txtDataFile = ConfigurationManager.AppSettings[$"{prefix}TxtDataFile"];
            outputFolder = ConfigurationManager.AppSettings[$"{prefix}OutputFolder"];
        }


        private void checkBoxRisk_CheckedChanged(object sender, EventArgs e)
        {

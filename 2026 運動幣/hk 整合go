;WITH DupData AS (
    SELECT 
        A.ID,
        ROW_NUMBER() OVER (
            PARTITION BY 
                A.TemplateId,
                A.GroupId,
                A.Parameter1,
                A.Parameter2,
                A.Parameter3,
                A.Parameter4,
                A.Parameter5,
                A.Parameter6,
                A.Parameter7,
                A.Parameter8,
                A.Parameter9,
                A.Parameter10,
                A.Score,
                A.Enabled,
                A.Deleted,
                A.Repeatable,
                A.Category,
                A.qryId
            ORDER BY A.ID
        ) AS RN
    FROM HRS_QuerySyntaxes A
    INNER JOIN VERIFY..HRS_QuerySyntaxes B
        ON ISNULL(A.TemplateId,0) = ISNULL(B.TemplateId,0)

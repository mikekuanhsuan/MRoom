✨ Step 1：新增欄位

ALTER TABLE BSADBTW..HRS_QuerySyntaxes
ADD DataTag INT NULL;

⸻

🟢 Step 2：標記「原始資料 = 1」

;WITH Ranked AS (
    SELECT 
        ID,
        ROW_NUMBER() OVER (
            PARTITION BY
                TemplateId,
                GroupId,
                Parameter1,
                Parameter2,
                Parameter3,
                Parameter4,
                Parameter5,
                Parameter6,
                Parameter7,
                Parameter8,
                Parameter9,
                Parameter10,
                Score,
                Enabled,
                Deleted,
                Repeatable,
                Category,
                qryId
            ORDER BY ID
        ) AS RN
    FROM BSADBTW..HRS_QuerySyntaxes
)
UPDATE A
SET DataTag = 1
FROM BSADBTW..HRS_QuerySyntaxes A
JOIN Ranked R ON A.ID = R.ID
WHERE R.RN = 1;

⸻

🔴 Step 3：標記「後來匯入 = 2」

;WITH Ranked AS (
    SELECT 
        ID,
        ROW_NUMBER() OVER (
            PARTITION BY
                TemplateId,
                GroupId,
                Parameter1,
                Parameter2,
                Parameter3,
                Parameter4,
                Parameter5,
                Parameter6,
                Parameter7,
                Parameter8,
                Parameter9,
                Parameter10,
                Score,
                Enabled,
                Deleted,
                Repeatable,
                Category,
                qryId
            ORDER BY ID
        ) AS RN
    FROM BSADBTW..HRS_QuerySyntaxes
)
UPDATE A
SET DataTag = 2
FROM BSADBTW..HRS_QuerySyntaxes A
JOIN Ranked R ON A.ID = R.ID
WHERE R.RN > 1;

⸻

💣 Step 4：真正刪除（你要的）

DELETE
FROM BSADBTW..HRS_QuerySyntaxes
WHERE DataTag = 2;


💡 方案 1（推薦）：CTE 標籤版

✔ 不改 table

✔ 可重複跑

✔ 安全

;WITH Ranked AS (
    SELECT 
        *,
        ROW_NUMBER() OVER (
            PARTITION BY
                TemplateId,
                GroupId,
                Parameter1,
                Parameter2,
                Parameter3,
                Parameter4,
                Parameter5,
                Parameter6,
                Parameter7,
                Parameter8,
                Parameter9,
                Parameter10,
                Score,
                Enabled,
                Deleted,
                Repeatable,
                Category,
                qryId
            ORDER BY ID
        ) AS RN
    FROM BSADBTW..HRS_QuerySyntaxes
)
SELECT COUNT(*) AS WillDeleteCount
FROM Ranked
WHERE RN > 1;


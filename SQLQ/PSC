##$args="NBINST01.json"
if ($args.Count -ne 1) {
    Write-Host "Please provide THE CONFIG JSON FILE"
    $dirname = Get-WorkPath
    $scriptName = $MyInvocation.MyCommand.Name
    Write-Host "USAGE: $dirname\$scriptName <LDAP CONF FILE>"
  exit 0
} else {
  $ldapconf = $args[0]
  ## DEBUG USE
  ##Write-Host "Ldap config file: $ldapconf"
}

$configFile = Join-Path -Path (Get-WorkPath) -ChildPath "$ldapconf"
if(Test-path $configFile -PathType leaf){
   $config = Get-Content $configFile -Raw | ConvertFrom-Json
} else {
   write-host $configFile " NOT EXIST .. Please Check"
   exit 0
}

$cmd = $config.ldapInfo.cmd
$remoteIP = $config.ldapInfo.remoteIP
$svrIPPort = $config.ldapInfo.svrIPPort
$appResCode = $config.ldapInfo.appResCode
$idPwd = Get-IdPwd -svrIPPort $svrIPPort -appResCode $appResCode
$user=$idPwd[0]
$password=$idPwd[1]
## DEBUG USAGE
# write-output $user
# write-output $password
## 等LDAP 設定完成, 就可以不需要下列 hard-coding password
#$user="filescan"
#$password="1qaz@WSX"
$winrs_command="winrs -r:$remoteIP "
$winrs_command=$winrs_command + "-u:$user -p:$password "
$winrs_command=$winrs_command + "powershell $cmd"
# write-host $winrs_command
# 執行指令隱藏密碼資訊
Invoke-Expression $winrs_command

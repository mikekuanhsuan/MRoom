
-- 確認有沒有重複的 refNo 然後有不同的 isdeled
WITH BaseData AS (
    SELECT * FROM RP_NP_Migrate_buffer 
    WHERE CIFKEY IN (
        SELECT CIF_KEY 
        FROM Customer_Migrate_buffer 
        WHERE customerNo IN (
            SELECT SK_CUST_ID 
            FROM BANCS_SK_CUST_INFO 
            WHERE TS_CUST_ID IN (
                SELECT TS_CUST_ID 
                FROM BANCS_SK_CUST_INFO 
            )
        )
    ) 
    AND RP = 'BOD'
)
-- 2. 從中篩選出：同一個 RefNo 卻同時擁有不同 isDeleted 值的資料
SELECT * FROM BaseData A
WHERE EXISTS (
    SELECT 1 
    FROM BaseData B 
    WHERE A.RefNo = B.RefNo 
      AND A.isDeleted <> B.isDeleted
)
ORDER BY RefNo, isDeleted;




-- 4. 嚴格定義需求和供給表 (遵循你的邏輯)
SELECT 
    月份, col, val,
    ROW_NUMBER() OVER(PARTITION BY col ORDER BY 月份) AS rn
INTO #Demand
FROM #Base
WHERE LEFT(月份, 6) <= '202705' 
  AND val > 0;  -- 需求：嚴格限定前11行的正數

SELECT 
    月份, col, -val AS supply,
    ROW_NUMBER() OVER(PARTITION BY col ORDER BY 月份) AS rn
INTO #Supply
FROM #Base
WHERE LEFT(月份, 6) >= '202706' 
  AND val < 0;  -- 供給：嚴格限定後7行的負數 (自動略過正數)

-- 5. 遞迴分配 CTE (使用 CAST 鎖死型態，防止無窮迴圈)
WITH RecursiveAllocation AS (
    SELECT
        d.col, d.月份 AS 需求月份, s.月份 AS 供給月份, d.rn AS d_rn, s.rn AS s_rn,
        CAST(IIF(d.val < s.supply, d.val, s.supply) AS DECIMAL(18,4)) AS 分配量,
        CAST(IIF(d.val < s.supply, 0, d.val - s.supply) AS DECIMAL(18,4)) AS remaining_demand,
        CAST(IIF(d.val < s.supply, s.supply - d.val, 0) AS DECIMAL(18,4)) AS remaining_supply
    FROM #Demand d
    JOIN #Supply s ON d.col = s.col AND d.rn = 1 AND s.rn = 1

    UNION ALL

    SELECT
        prev.col, next_d.月份, next_s.月份, next_d.rn AS d_rn, next_s.rn AS s_rn,
        CAST(IIF(IIF(prev.remaining_demand > 0, prev.remaining_demand, next_d.val) < IIF(prev.remaining_supply > 0, prev.remaining_supply, next_s.supply), IIF(prev.remaining_demand > 0, prev.remaining_demand, next_d.val), IIF(prev.remaining_supply > 0, prev.remaining_supply, next_s.supply)) AS DECIMAL(18,4)) AS 分配量,
        CAST(IIF(prev.remaining_demand > 0, prev.remaining_demand, next_d.val) - IIF(IIF(prev.remaining_demand > 0, prev.remaining_demand, next_d.val) < IIF(prev.remaining_supply > 0, prev.remaining_supply, next_s.supply), IIF(prev.remaining_demand > 0, prev.remaining_demand, next_d.val), IIF(prev.remaining_supply > 0, prev.remaining_supply, next_s.supply)) AS DECIMAL(18,4)) AS remaining_demand,
        CAST(IIF(prev.remaining_supply > 0, prev.remaining_supply, next_s.supply) - IIF(IIF(prev.remaining_demand > 0, prev.remaining_demand, next_d.val) < IIF(prev.remaining_supply > 0, prev.remaining_supply, next_s.supply), IIF(prev.remaining_demand > 0, prev.remaining_demand, next_d.val), IIF(prev.remaining_supply > 0, prev.remaining_supply, next_s.supply)) AS DECIMAL(18,4)) AS remaining_supply
    FROM RecursiveAllocation prev
    JOIN #Demand next_d ON prev.col = next_d.col AND next_d.rn = IIF(prev.remaining_demand = 0, prev.d_rn + 1, prev.d_rn)
    JOIN #Supply next_s ON prev.col = next_s.col AND next_s.rn = IIF(prev.remaining_supply = 0, prev.s_rn + 1, prev.s_rn)
)

SELECT 需求月份, 供給月份, 分配量, col AS 列標籤
INTO #FinalResult
FROM RecursiveAllocation
WHERE 分配量 > 0
OPTION (MAXRECURSION 0);

-- 6. 輸出
PRINT '--- 詳細分配結果 ---';
SELECT * FROM #FinalResult ORDER BY 列標籤, 需求月份, 供給月份;

PRINT '--- 報表1: 按「需求月份」加總 ---';
SELECT 需求月份, SUM(分配量) AS 該月份總需求分配量 FROM #FinalResult GROUP BY 需求月份 ORDER BY 需求月份;

PRINT '--- 報表2: 按「供給月份」加總 (包含 Excel 淨值對帳欄位) ---';
SELECT 
    b.月份 AS 供給月份,
    SUM(b.val) AS 該月淨值加總_完全吻合Excel,      -- 這裡出來的數字就會是你要的 -6951、-8445
    -ISNULL(f.已分配供給, 0) AS 其中拿去分配的負數供給 -- 這裡呈現實際在引擎裡被配掉的純負數
FROM #Base b
LEFT JOIN (
    SELECT 供給月份, SUM(分配量) AS 已分配供給 FROM #FinalResult GROUP BY 供給月份
) f ON b.月份 = f.供給月份
WHERE LEFT(b.月份, 6) >= '202706'
GROUP BY b.月份, f.已分配供給
ORDER BY b.月份;

PRINT '--- 報表3: 每個列標籤的加總對帳表 ---';
SELECT 
    COALESCE(d.col, s.col) AS 列標籤,
    ISNULL(d.總需求, 0) AS 前11個月總需求量,
    -ISNULL(s.總供給, 0) AS 後7個月可分配之純負數總和,   
    ISNULL(f.總分配量, 0) AS 已成功配對量,
    ISNULL(d.總需求, 0) - ISNULL(f.總分配量, 0) AS 未滿足的需求量_缺貨,
    -(ISNULL(s.總供給, 0) - ISNULL(f.總分配量, 0)) AS 剩餘未分配的純負數_庫存 
FROM (SELECT col, SUM(val) AS 總需求 FROM #Demand GROUP BY col) d
FULL OUTER JOIN (SELECT col, SUM(supply) AS 總供給 FROM #Supply GROUP BY col) s ON d.col = s.col
LEFT JOIN (SELECT 列標籤, SUM(分配量) AS 總分配量 FROM #FinalResult GROUP BY 列標籤) f ON COALESCE(d.col, s.col) = f.列標籤
ORDER BY 列標籤;


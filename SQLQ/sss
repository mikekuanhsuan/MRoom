' 函數：從 "列標籤" 工作表產生 SQL IN 子句
Private Function GetBranchInClause(ws As Worksheet) As String

    Dim lastRow As Long
    Dim cell As Range
    Dim arr As Object

    Set arr = CreateObject("System.Collections.ArrayList")

    lastRow = ws.Cells(ws.Rows.Count, "A").End(xlUp).Row

    For Each cell In ws.Range("A2:A" & lastRow)

        If Trim(cell.Value) <> "" Then

            arr.Add "'" & Replace(Trim(cell.Value), "_", "") & "'"

        End If

    Next cell

    GetBranchInClause = Join(arr.ToArray(), ", ")

End Function

' 函數：從 "中風險" 工作表產生完整的 SQL 腳本 (此函數無需修改)
Private Function GenerateSqlFromRiskData(ws As Worksheet, branchInClause As String, riskLevel As String, ByVal nextCheckMap As Object) As String
    Dim lastRow As Long
    lastRow = ws.Cells(ws.Rows.Count, "A").End(xlUp).Row
    If lastRow <= 1 Then Exit Function
    
    Dim dataRange As Range
    Set dataRange = ws.Range("A2:D" & lastRow) ' 讀取 A 到 D 欄
    
    Dim groups As Object
    Set groups = CreateObject("Scripting.Dictionary")
    
    Dim r As Long
    For r = 1 To dataRange.Rows.Count
        Dim supplyMonth As String, demandMonth As String, branchLabel As String
        Dim allocation As Double
        
        demandMonth = GetNumericPart(CStr(dataRange.Cells(r, 1).Value))
        supplyMonth = GetNumericPart(CStr(dataRange.Cells(r, 2).Value))
        branchLabel = Replace(Trim(CStr(dataRange.Cells(r, 4).Value)), "_", "", 1, 1)
        
        If IsNumeric(dataRange.Cells(r, 3).Value) Then
            allocation = CDbl(dataRange.Cells(r, 3).Value)
        Else
            allocation = 0
        End If
        
        If supplyMonth <> "" And demandMonth <> "" And branchLabel <> "" Then
            Dim groupKey As String
            groupKey = supplyMonth & "_" & demandMonth
            
            If Not groups.Exists(groupKey) Then
                Set groups(groupKey) = CreateObject("Scripting.Dictionary")
            End If
            
            If groups(groupKey).Exists(branchLabel) Then
                groups(groupKey)(branchLabel) = groups(groupKey)(branchLabel) + allocation
            Else
                groups(groupKey)(branchLabel) = allocation
            End If
        End If
    Next r
    
    Dim finalSqlBuilder As String
    Dim groupKeyVariant As Variant
    Dim branchLabelVariant As Variant
    Dim branchOffset As Object
    Set branchOffset = CreateObject("Scripting.Dictionary")
        
    Dim riskDesc As String
    Select Case riskLevel
        Case "H": riskDesc = "高風險"
        Case "M": riskDesc = "中風險"
        Case "L": riskDesc = "低風險"
        Case Else: riskDesc = "未知風險"
    End Select
    

    Dim sortedKeys() As String
    Dim keyCount As Long
    Dim i As Long
    Dim j As Long
    Dim tempKey As String
    keyCount = groups.Count
    ReDim sortedKeys(0 To keyCount - 1)
    i = 0
    For Each groupKeyVariant In groups.Keys
        sortedKeys(i) = CStr(groupKeyVariant)
        i = i + 1
    Next
    For i = 0 To UBound(sortedKeys) - 1
        For j = i + 1 To UBound(sortedKeys)
            If sortedKeys(i) > sortedKeys(j) Then
                tempKey = sortedKeys(i)
                sortedKeys(i) = sortedKeys(j)
                sortedKeys(j) = tempKey
            End If
        Next j
    Next i
    For i = 0 To UBound(sortedKeys)
        groupKeyVariant = sortedKeys(i)

        Dim parts() As String
        parts = Split(groupKeyVariant, "_")
        Dim supply As String, demand As String, nextCheck As String
        supply = parts(0)
        demand = parts(1)
        
        If nextCheckMap.Exists(demand) Then
            nextCheck = nextCheckMap(demand)
        Else
            nextCheck = "YYYYMMDD_NotFound"
        End If
        
        Dim condList As Object
        Set condList = CreateObject("System.Collections.ArrayList")
        
        Dim branchConditions As Object
        Set branchConditions = groups(groupKeyVariant)
        
        
            
        For Each branchLabelVariant In branchConditions.Keys
            Dim allocCnt As Long
            Dim startCnt As Long
            Dim endCnt As Long
            allocCnt = CLng(branchConditions(branchLabelVariant))
            If branchOffset.Exists(branchLabelVariant) Then
                startCnt = branchOffset(branchLabelVariant) + 1
            Else
                startCnt = 1
            End If
            endCnt = startCnt + allocCnt - 1
            condList.Add _
                "(BRNCH_NBR = '" & branchLabelVariant & _
                "' AND CNT BETWEEN " & startCnt & _
                " AND " & endCnt & ")"
            branchOffset(branchLabelVariant) = endCnt
        Next branchLabelVariant

        Dim whereConditions As String
        whereConditions = Join(condList.ToArray(), " OR" & vbCrLf)
        
        Dim sqlTemplate As String
        sqlTemplate = "-- =============================================" & vbCrLf
        sqlTemplate = sqlTemplate & "-- 集中處理 - " & riskDesc & "客戶 (" & supply & " 供給 → " & demand & " 需求)" & vbCrLf
        sqlTemplate = sqlTemplate & "-- =============================================" & vbCrLf
        sqlTemplate = sqlTemplate & "INSERT INTO @CustData" & vbCrLf
        sqlTemplate = sqlTemplate & "SELECT CustomerNo, '" & nextCheck & "'" & vbCrLf
        sqlTemplate = sqlTemplate & "FROM (" & vbCrLf
        sqlTemplate = sqlTemplate & "    SELECT " & vbCrLf
        sqlTemplate = sqlTemplate & "        A.CustomerNo," & vbCrLf
        sqlTemplate = sqlTemplate & "        D.BRNCH_NBR," & vbCrLf
        sqlTemplate = sqlTemplate & "        DENSE_RANK() OVER (PARTITION BY D.BRNCH_NBR ORDER BY A.CIF_KEY) AS CNT" & vbCrLf
        sqlTemplate = sqlTemplate & "    FROM (" & vbCrLf
        sqlTemplate = sqlTemplate & "        SELECT CIF_KEY, CustomerNo " & vbCrLf
        sqlTemplate = sqlTemplate & "        FROM BSADBTW..BSA_SUB_CUST_FACT WITH (NOLOCK)" & vbCrLf
        sqlTemplate = sqlTemplate & "        WHERE HIGHRISK = '" & riskLevel & "'" & vbCrLf
        sqlTemplate = sqlTemplate & "    ) A" & vbCrLf
        sqlTemplate = sqlTemplate & "" & vbCrLf
        sqlTemplate = sqlTemplate & "    INNER JOIN BSADBTW..PB_CUSTOMER_FACT D WITH (NOLOCK)" & vbCrLf
        sqlTemplate = sqlTemplate & "        ON A.CIF_KEY = D.CIF_KEY " & vbCrLf
        sqlTemplate = sqlTemplate & "    AND D.BRNCH_NBR IN (" & branchInClause & ")" & vbCrLf
        sqlTemplate = sqlTemplate & "    AND D.RecordStatus = 'O'" & vbCrLf
        sqlTemplate = sqlTemplate & "    AND D.Customer_Segment <> 'NCR'" & vbCrLf
        sqlTemplate = sqlTemplate & "" & vbCrLf
        sqlTemplate = sqlTemplate & "    INNER JOIN BSADBTW..EDD_ReviewSchedule B WITH (NOLOCK)" & vbCrLf
        sqlTemplate = sqlTemplate & "        ON A.CIF_KEY = B.CIFKey " & vbCrLf
        sqlTemplate = sqlTemplate & "    AND B.Status = 'P'" & vbCrLf
        sqlTemplate = sqlTemplate & "    AND B.ReviewDt >= '" & supply & "01 00:00:00.000'" & vbCrLf
        sqlTemplate = sqlTemplate & "    AND B.ReviewDt <= '" & supply & Day(DateSerial(Left(supply, 4), Right(supply, 2) + 1, 0)) & " 23:59:59.999'" & vbCrLf
        sqlTemplate = sqlTemplate & "" & vbCrLf
        sqlTemplate = sqlTemplate & "    LEFT JOIN (" & vbCrLf
        sqlTemplate = sqlTemplate & "        SELECT CIF_KEY " & vbCrLf
        sqlTemplate = sqlTemplate & "        FROM BSADBTW..HRS_CUST_RISK_MGMT WITH (NOLOCK)" & vbCrLf
        sqlTemplate = sqlTemplate & "        WHERE STATUS <> '3'" & vbCrLf
        sqlTemplate = sqlTemplate & "    ) C ON A.CIF_KEY = C.CIF_KEY" & vbCrLf
        sqlTemplate = sqlTemplate & "" & vbCrLf
        sqlTemplate = sqlTemplate & "    WHERE C.CIF_KEY IS NULL" & vbCrLf
        sqlTemplate = sqlTemplate & ") T" & vbCrLf
        sqlTemplate = sqlTemplate & "" & vbCrLf
        sqlTemplate = sqlTemplate & "WHERE " & vbCrLf
        sqlTemplate = sqlTemplate & whereConditions & vbCrLf
            
        finalSqlBuilder = finalSqlBuilder & sqlTemplate & vbCrLf
    Next i
    
    GenerateSqlFromRiskData = finalSqlBuilder
End Function

' 輔助函數：從字串中提取數字部分
Private Function GetNumericPart(text As String) As String
    Dim regEx As Object
    Set regEx = CreateObject("VBScript.RegExp")
    regEx.Pattern = "\d+"
    regEx.Global = False
    If regEx.Test(text) Then GetNumericPart = regEx.Execute(text)(0) Else GetNumericPart = ""
End Function





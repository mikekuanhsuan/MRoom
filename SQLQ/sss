PRINT '--- 報表3: 每個列標籤的加總對帳表 (可找出哪裡有庫存/缺貨) ---';
SELECT 
    COALESCE(d.col, s.col) AS 列標籤,
    ISNULL(d.總需求, 0) AS 總需求量,
    ISNULL(s.總供給, 0) AS 總供給量,
    ISNULL(f.總分配量, 0) AS 已成功分配量,
    ISNULL(d.總需求, 0) - ISNULL(f.總分配量, 0) AS 未滿足的需求量_缺貨,
    ISNULL(s.總供給, 0) - ISNULL(f.總分配量, 0) AS 剩餘未分配供給量_庫存
FROM (
    SELECT col, SUM(val) AS 總需求 FROM #Demand GROUP BY col
) d
FULL OUTER JOIN (
    SELECT col, SUM(supply) AS 總供給 FROM #Supply GROUP BY col
) s ON d.col = s.col
LEFT JOIN (
    SELECT 列標籤, SUM(分配量) AS 總分配量 FROM #FinalResult GROUP BY 列標籤
) f ON COALESCE(d.col, s.col) = f.列標籤
ORDER BY 列標籤;

建議正式版

USE HKDB
GO
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
ALTER PROCEDURE dbo.SP_AMLM007_REDFLAG_REPORT_HK
AS
BEGIN
    SET NOCOUNT OFF;
    DROP TABLE IF EXISTS ##AMLM007_REDFLAG_REPORT_HK;
    ;WITH Combined_List AS
    (
        SELECT 'LOAN' AS SOURCE_TYPE,
               LON_NO AS DOC_NO,
               LON_CCY AS CURRENCY,
               LON_AMT AS AMOUNT,
               CIF_CUST_INFO_SEQ,
               AML_INFO_SEQ,
               TRADE_DATE
        FROM WBS_LON_INFO
        UNION ALL
        SELECT 'LC_CREATE',
               LC_NO,
               LC_NO_CCY,
               LC_NO_AMT,
               CIF_CUST_INFO_SEQ,
               AML_INFO_SEQ,
               TRADE_DATE
        FROM WBS_IMP_LC
        UNION ALL
        SELECT 'LC_AMEND',
               LC_NO,
               LC_NO_CCY,
               NEW_AMT,
               CIF_CUST_INFO_SEQ,
               AML_INFO_SEQ,
               TRADE_DATE
        FROM WBS_IMP_LC
        UNION ALL
        SELECT 'SGED',
               SGED_NO,
               SGED_CCY,
               SGED_AMT,
               CIF_CUST_INFO_SEQ,
               AML_INFO_SEQ,
               TRADE_DATE
        FROM WBS_IMP_SGED
        UNION ALL
        SELECT 'IB',
               IB_NO,
               BILL_CCY,
               BILL_AMT1,
               CIF_CUST_INFO_SEQ,
               AML_INFO_SEQ,
               TRADE_DATE
        FROM WBS_IMP_IB
        UNION ALL
        SELECT 'IC',
               IC_NO,
               BILL_CCY,
               BILL_AMT,
               CIF_CUST_INFO_SEQ,
               AML_INFO_SEQ,
               TRADE_DATE
        FROM WBS_IMP_IC
        UNION ALL
        SELECT 'LA',
               LA_NO,
               LC_CCY,
               LC_AMT,
               CIF_CUST_INFO_SEQ,
               AML_INFO_SEQ,
               TRADE_DATE
        FROM WBS_EXP_LA_INFO
        UNION ALL
        SELECT 'LT',
               LT_NO,
               LC_CCY,
               LT_AMT,
               CIF_CUST_INFO_SEQ,
               AML_INFO_SEQ,
               TRADE_DATE
        FROM WBS_EXP_LT_INFO
        UNION ALL
        SELECT 'NEGO',
               NEGO_NO,
               BILL_CCY,
               BILL_AMT,
               CIF_CUST_INFO_SEQ,
               AML_INFO_SEQ,
               TRADE_DATE
        FROM WBS_EXP_NEGO_INFO
        UNION ALL
        SELECT 'RENEGO',
               REF_NO,
               BILL_CCY,
               BILL_AMT,
               CIF_CUST_INFO_SEQ,
               AML_INFO_SEQ,
               TRADE_DATE
        FROM WBS_EXP_RE_NEGO_INFO
        UNION ALL
        SELECT 'OC',
               OC_NO,
               BILL_CCY,
               BILL_AMT,
               CIF_CUST_INFO_SEQ,
               AML_INFO_SEQ,
               TRADE_DATE
        FROM WBS_EXP_OC_INFO
    )
    SELECT
         E.SOURCE_TYPE
        ,E.DOC_NO
        ,E.CURRENCY
        ,E.AMOUNT
        ,E.TRADE_DATE
        ,'_' + ISNULL(C.CUSTOMER_ID,'') AS CUSTOMER_ID
        ,F.FUNC_NAME
        ,AML.FLAG
        ,AML.CONTENT
        ,GOODSCODE.CONTENT      AS GOODSCODE
        ,MERCHANDISE.CONTENT    AS MERCHANDISE
        ,VESSEL_NAME.CONTENT    AS VESSEL_NAME
        ,FLAG_VESSEL.CONTENT    AS FLAG_VESSEL
        ,REMARK.CONTENT         AS REMARK
        ,TAG44A.CONTENT         AS PORT_OF_LOADING
        ,TAG44E.CONTENT         AS PORT_OF_DISCHARGE
        ,TAG44F.CONTENT         AS PORT_OF_TRANSSHIPMENT
        ,TAG44B.CONTENT         AS FINAL_DESTINATION
    INTO ##AMLM007_REDFLAG_REPORT_HK
    FROM Combined_List E
    LEFT JOIN WBS_CIF_CUST_INFO C
        ON E.CIF_CUST_INFO_SEQ = C.CIF_CUST_INFO_SEQ
    LEFT JOIN
    (
        SELECT *
        FROM WBS_AML_DETAIL
        WHERE AML_TYPE='RED_FLAG'
    ) AML
        ON E.AML_INFO_SEQ = AML.AML_INFO_SEQ
    LEFT JOIN WBS_RAA_FUNC_INFO F
        ON AML.FUN_CODE = F.FUNC_CODE
    LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WHERE AML_TYPE='GOODSCODE') GOODSCODE
        ON E.AML_INFO_SEQ=GOODSCODE.AML_INFO_SEQ
    LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WHERE AML_TYPE='MERCHANDISE') MERCHANDISE
        ON E.AML_INFO_SEQ=MERCHANDISE.AML_INFO_SEQ
    LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WHERE AML_TYPE='VESSEL_NAME') VESSEL_NAME
        ON E.AML_INFO_SEQ=VESSEL_NAME.AML_INFO_SEQ
    LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WHERE AML_TYPE='FLAG_VESSEL') FLAG_VESSEL
        ON E.AML_INFO_SEQ=FLAG_VESSEL.AML_INFO_SEQ
    LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WHERE AML_TYPE='REMARK') REMARK
        ON E.AML_INFO_SEQ=REMARK.AML_INFO_SEQ
    LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WHERE AML_TYPE='TAG44A_CONTENT') TAG44A
        ON E.AML_INFO_SEQ=TAG44A.AML_INFO_SEQ
    LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WHERE AML_TYPE='TAG44E_CONTENT') TAG44E
        ON E.AML_INFO_SEQ=TAG44E.AML_INFO_SEQ
    LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WHERE AML_TYPE='TAG44F_CONTENT') TAG44F
        ON E.AML_INFO_SEQ=TAG44F.AML_INFO_SEQ
    LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WHERE AML_TYPE='TAG44B_CONTENT') TAG44B
        ON E.AML_INFO_SEQ=TAG44B.AML_INFO_SEQ
    WHERE
    (
        LEFT(E.TRADE_DATE,6)
            =
        CONVERT(VARCHAR(6),DATEADD(MONTH,-1,GETDATE()),112)
        OR @@SERVERNAME='OBODS_TEST'
    )
    AND AML.FLAG='Y';
    DECLARE @SQL NVARCHAR(MAX)='';
    ;WITH TBLCOLNME AS
    (
        SELECT
            C.OBJECT_ID,
            C.NAME
        FROM TEMPDB.SYS.TABLES T
        JOIN TEMPDB.SYS.COLUMNS C
            ON T.OBJECT_ID=C.OBJECT_ID
        WHERE T.NAME='##AMLM007_REDFLAG_REPORT_HK'
    )
    SELECT DISTINCT
        @SQL=
        STUFF(
            (
                SELECT CONCAT(',"',A.NAME,'"')
                FROM TBLCOLNME A
                WHERE A.OBJECT_ID=B.OBJECT_ID
                FOR XML PATH('')
            ),
            1,
            1,
            ''
        )
    FROM TBLCOLNME B;
    SET @SQL=
        CONCAT(
            'SELECT ''',
            @SQL,
            ''' AS COL ',
            ' UNION ALL ',
            ' SELECT CONCAT(',
            REPLACE(@SQL,',',',CHAR(9),'),
            ') FROM ##AMLM007_REDFLAG_REPORT_HK '
        );
    SET @SQL=
        @SQL +
        ' UNION ALL SELECT ''*** End of Report ***'' ';
    EXEC(@SQL);
END
GO

⚠️ 上正式前我會建議你先驗證兩件事：

1. AML.FUN_CODE 是否真的存在。
2. ##AMLM007_REDFLAG_REPORT_HK 最後輸出的 TAB 格式是否與 AMLM005 完全一致。

因為 Informatica 最容易出問題的不是 SQL 本身，而是最後輸出的欄位格式。這部分最好直接複製 AMLM005 的 Dynamic SQL 段落，不要自行簡化。


@


如果你現在的目的只是 測 SP 有沒有寫對、資料有沒有抓對，其實不用做到 Informatica 那麼複雜。

我平常會這樣驗：

⸻

Step 1 先把日期固定

先不要用：

LEFT(E.TRADE_DATE,6) =
CONVERT(VARCHAR(6),DATEADD(MONTH,-1,GETDATE()),112)

改成你有資料的月份：

E.TRADE_DATE BETWEEN '20251101' AND '20251130'

避免因為月份沒資料誤判 SP 有問題。

⸻

Step 2 先測 Combined_List

確認 11 個來源表都有資料。

;WITH Combined_List AS
(
    ...
)
SELECT
    SOURCE_TYPE,
    COUNT(*) CNT
FROM Combined_List
GROUP BY SOURCE_TYPE
ORDER BY SOURCE_TYPE;

預期：

SOURCE_TYPE	CNT
LOAN	xx
LC_CREATE	xx
LC_AMEND	xx
SGED	xx
IB	xx
IC	xx
LA	xx
LT	xx
NEGO	xx
RENEGO	xx
OC	xx

如果某個是 0，就去查那張來源表。

⸻

Step 3 測 AML 關聯

確認 AML_INFO_SEQ 能 Join 到資料。

;WITH Combined_List AS
(
    ...
)
SELECT COUNT(*) CNT
FROM Combined_List E
INNER JOIN WBS_AML_DETAIL A
    ON E.AML_INFO_SEQ = A.AML_INFO_SEQ
WHERE A.AML_TYPE='RED_FLAG';

預期：

CNT > 0

⸻

Step 4 測 FLAG=Y

;WITH Combined_List AS
(
    ...
)
SELECT
    A.FLAG,
    COUNT(*) CNT
FROM Combined_List E
JOIN WBS_AML_DETAIL A
    ON E.AML_INFO_SEQ=A.AML_INFO_SEQ
WHERE A.AML_TYPE='RED_FLAG'
GROUP BY A.FLAG;

預期：

Y    xxx
N    xxx

至少有 Y。

⸻

Step 5 測主查詢

直接跑：

;WITH Combined_List AS
(
    ...
)
SELECT TOP 100
    E.SOURCE_TYPE,
    E.DOC_NO,
    E.TRADE_DATE,
    C.CUSTOMER_ID,
    AML.FLAG,
    AML.CONTENT
FROM Combined_List E
LEFT JOIN WBS_CIF_CUST_INFO C
    ON E.CIF_CUST_INFO_SEQ=C.CIF_CUST_INFO_SEQ
LEFT JOIN WBS_AML_DETAIL AML
    ON E.AML_INFO_SEQ=AML.AML_INFO_SEQ
    AND AML.AML_TYPE='RED_FLAG'
WHERE AML.FLAG='Y';

看資料是否合理。

⸻

Step 6 驗 CUSTOMER_ID

抽一筆：

SELECT TOP 1 *
FROM ##AMLM007_REDFLAG_REPORT_HK

記下：

CUSTOMER_ID

然後回查：

SELECT *
FROM WBS_CIF_CUST_INFO
WHERE CUSTOMER_ID='剛剛那筆'

確認一致。

⸻

Step 7 驗 AML 欄位

抽一筆：

SELECT TOP 1
       AML_INFO_SEQ
FROM ##AMLM007_REDFLAG_REPORT_HK

例如：

AML_INFO_SEQ = 12345

查：

SELECT *
FROM WBS_AML_DETAIL
WHERE AML_INFO_SEQ=12345

確認：

* FLAG
* CONTENT
* GOODSCODE
* MERCHANDISE
* VESSEL_NAME

跟報表一致。

⸻

Step 8 執行 SP

EXEC dbo.SP_AMLM007_REDFLAG_REPORT_HK

如果沒有報錯：

Invalid column name
Invalid object name
Conversion failed

代表 SP 至少能正常跑。

⸻

Step 9 驗證筆數

最重要的一步。

SP 主查詢：

SELECT COUNT(*) CNT

假設得到：

58

然後 TEMP TABLE：

SELECT COUNT(*)
FROM ##AMLM007_REDFLAG_REPORT_HK

也應該：

58

如果不一致就有問題。

⸻

你如果是 SIT 階段，我通常只做 4 個 Test Case：

TC	驗證內容	SQL
TC01	Combined_List 有資料	COUNT(*)
TC02	AML_INFO_SEQ 關聯成功	JOIN AML_DETAIL
TC03	FLAG=‘Y’ 過濾正確	GROUP BY FLAG
TC04	SP 成功產出資料	EXEC SP + COUNT

這 4 個就足夠證明 SP 邏輯正確了。


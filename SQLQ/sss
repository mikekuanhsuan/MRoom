-- 4. 自動分離需求和供給表 (大於0為需求，小於0轉換後為供給)
SELECT 
    月份, col, val,
    ROW_NUMBER() OVER(PARTITION BY col ORDER BY 月份) AS rn
INTO #Demand
FROM #Base
WHERE val > 0;

SELECT 
    月份, col, -val AS supply,
    ROW_NUMBER() OVER(PARTITION BY col ORDER BY 月份) AS rn
INTO #Supply
FROM #Base
WHERE val < 0;

-- 5. 修正後的遞迴 CTE 計算分配結果
WITH RecursiveAllocation AS (
    -- Anchor member (遞迴起點：各品項第一個需求對上第一個供給)
    SELECT
        d.col,
        d.月份 AS 需求月份,
        s.月份 AS 供給月份,
        d.rn AS d_rn,
        s.rn AS s_rn,
        IIF(d.val < s.supply, d.val, s.supply) AS 分配量,
        IIF(d.val < s.supply, 0, d.val - s.supply) AS remaining_demand,
        IIF(d.val < s.supply, s.supply - d.val, 0) AS remaining_supply
    FROM #Demand d
    JOIN #Supply s ON d.col = s.col AND d.rn = 1 AND s.rn = 1

    UNION ALL

    -- Recursive member (遞迴段落)
    SELECT
        prev.col,
        next_d.月份,
        next_s.月份,
        next_d.rn AS d_rn,
        next_s.rn AS s_rn,
        
        -- 分配量：抓「當前可用需求」與「當前可用供給」中較小的值
        IIF(
            IIF(prev.remaining_demand > 0, prev.remaining_demand, next_d.val) < IIF(prev.remaining_supply > 0, prev.remaining_supply, next_s.supply),
            IIF(prev.remaining_demand > 0, prev.remaining_demand, next_d.val),
            IIF(prev.remaining_supply > 0, prev.remaining_supply, next_s.supply)
        ) AS 分配量,
        
        -- 算新的剩餘需求 (當前需求 - 分配量)
        IIF(prev.remaining_demand > 0, prev.remaining_demand, next_d.val) - 
        IIF(
            IIF(prev.remaining_demand > 0, prev.remaining_demand, next_d.val) < IIF(prev.remaining_supply > 0, prev.remaining_supply, next_s.supply),
            IIF(prev.remaining_demand > 0, prev.remaining_demand, next_d.val),
            IIF(prev.remaining_supply > 0, prev.remaining_supply, next_s.supply)
        ) AS remaining_demand,
        
        -- 算新的剩餘供給 (當前供給 - 分配量)
        IIF(prev.remaining_supply > 0, prev.remaining_supply, next_s.supply) - 
        IIF(
            IIF(prev.remaining_demand > 0, prev.remaining_demand, next_d.val) < IIF(prev.remaining_supply > 0, prev.remaining_supply, next_s.supply),
            IIF(prev.remaining_demand > 0, prev.remaining_demand, next_d.val),
            IIF(prev.remaining_supply > 0, prev.remaining_supply, next_s.supply)
        ) AS remaining_supply

    FROM RecursiveAllocation prev
    -- 核心修正：如果上一輪的需求被扣光了(0)，就抓下一個月(rn+1)，否則繼續用同一個月(rn)
    JOIN #Demand next_d ON prev.col = next_d.col AND next_d.rn = IIF(prev.remaining_demand = 0, prev.d_rn + 1, prev.d_rn)
    JOIN #Supply next_s ON prev.col = next_s.col AND next_s.rn = IIF(prev.remaining_supply = 0, prev.s_rn + 1, prev.s_rn)
)

-- 將結果存入臨時表 #FinalResult
SELECT 
    需求月份,
    供給月份,
    分配量,
    col AS 列標籤
INTO #FinalResult
FROM RecursiveAllocation
WHERE 分配量 > 0
OPTION (MAXRECURSION 0);

-- 6. 輸出詳細分配結果
PRINT '--- 詳細分配結果 ---';
SELECT * FROM #FinalResult
ORDER BY 列標籤, 需求月份, 供給月份;

-- 7. 產生三種不同的加總報表
PRINT '--- 報表1: 按「需求月份」加總 ---';
SELECT 
    需求月份,
    SUM(分配量) AS 該月份總需求分配量
FROM #FinalResult
GROUP BY 需求月份
ORDER BY 需求月份;

PRINT '--- 報表2: 按「供給月份」加總 ---';
SELECT 
    供給月份,
    SUM(分配量) AS 該月份總供給分配量
FROM #FinalResult
GROUP BY 供給月份
ORDER BY 供給月份;

PRINT '--- 報表3: 按「列標籤」加總 ---';
SELECT 
    列標籤,
    SUM(分配量) AS 該標籤總分配量
FROM #FinalResult
GROUP BY 列標籤
ORDER BY 列標籤;

-- 8. 清理所有臨時表
DROP TABLE #Raw;
DROP TABLE #Base;
DROP TABLE #Demand;
DROP TABLE #Supply;
DROP TABLE #FinalResult;

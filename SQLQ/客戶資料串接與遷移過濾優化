SELECT
    AML_TYPE,
    COUNT(*) DUP_CNT
FROM
(
    SELECT
        AML_INFO_SEQ,
        AML_TYPE,
        COUNT(*) CNT
    FROM WBS_AML_DETAIL
    WHERE AML_TYPE IN
    (
        'RED_FLAG',
        'GOODSCODE',
        'MERCHANDISE',
        'VESSEL_NAME',
        'FLAG_VESSEL',
        'REMARK',
        'TAG44A_CONTENT',
        'TAG44E_CONTENT',
        'TAG44F_CONTENT',
        'TAG44B_CONTENT'
    )
    GROUP BY AML_INFO_SEQ, AML_TYPE
    HAVING COUNT(*) > 1
) A
GROUP BY AML_TYPE
ORDER BY AML_TYPE;


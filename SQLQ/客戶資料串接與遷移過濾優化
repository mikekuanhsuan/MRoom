現在我可以幫你組出完整骨架了，但因為你的主查詢實在太長（11個 UNION + 10個 AML JOIN），直接貼 300+ 行容易出現截斷。

你真正要做的是把 你的查詢放進下面這個框架。

ALTER PROCEDURE [dbo].[SP_AMLM007_REDFLAG_REPORT_HK]
AS
BEGIN
    SET NOCOUNT OFF;
    EXECUTE(N'DROP TABLE IF EXISTS ##AMLM007_REDFLAG_REPORT_HK');
    ;WITH Combined_List AS
    (
        -- 這裡放你的 Combined_List
        -- LOAN
        -- LC_CREATE
        -- LC_AMEND
        -- SGED
        -- IB
        -- IC
        -- LA
        -- LT
        -- NEGO
        -- RENEGO
        -- OC
    )
    SELECT
        E.SOURCE_TYPE,
        E.DOC_NO,
        E.CURRENCY,
        E.AMOUNT,
        E.TRADE_DATE,
        '_' + ISNULL(C.CUSTOMER_ID,'') AS CUSTOMER_ID,
        F.FUNC_NAME,
        AML.FLAG,
        AML.CONTENT,
        GOODSCODE.CONTENT AS GOODSCODE,
        MERCHANDISE.CONTENT AS MERCHANDISE,
        VESSEL_NAME.CONTENT AS VESSEL_NAME,
        FLAG_VESSEL.CONTENT AS FLAG_VESSEL,
        REMARK.CONTENT AS REMARK,
        TAG44A_CONTENT.CONTENT AS PORT_OF_LOADING,
        TAG44E_CONTENT.CONTENT AS PORT_OF_DISCHARGE,
        TAG44F_CONTENT.CONTENT AS PORT_OF_TRANSSHIPMENT,
        TAG44B_CONTENT.CONTENT AS FINAL_DESTINATION
    INTO ##AMLM007_REDFLAG_REPORT_HK
    FROM Combined_List E
    LEFT JOIN WBS_CIF_CUST_INFO C
        ON E.CIF_CUST_INFO_SEQ = C.CIF_CUST_INFO_SEQ
    LEFT JOIN
    (
        SELECT
            AML_INFO_SEQ,
            MAX(FLAG) AS FLAG,
            MAX(FUN_CODE) AS FUN_CODE,
            MAX(CONTENT) AS CONTENT
        FROM WBS_AML_DETAIL
        WHERE AML_TYPE='RED_FLAG'
        GROUP BY AML_INFO_SEQ
    ) AML
        ON E.AML_INFO_SEQ = AML.AML_INFO_SEQ
    LEFT JOIN WBS_RAA_FUNC_INFO F
        ON AML.FUN_CODE = F.FUNC_CODE
    LEFT JOIN
    (
        SELECT AML_INFO_SEQ, MAX(CONTENT) CONTENT
        FROM WBS_AML_DETAIL
        WHERE AML_TYPE='GOODSCODE'
        GROUP BY AML_INFO_SEQ
    ) GOODSCODE
        ON E.AML_INFO_SEQ = GOODSCODE.AML_INFO_SEQ
    LEFT JOIN
    (
        SELECT AML_INFO_SEQ, MAX(CONTENT) CONTENT
        FROM WBS_AML_DETAIL
        WHERE AML_TYPE='MERCHANDISE'
        GROUP BY AML_INFO_SEQ
    ) MERCHANDISE
        ON E.AML_INFO_SEQ = MERCHANDISE.AML_INFO_SEQ
    LEFT JOIN
    (
        SELECT AML_INFO_SEQ, MAX(CONTENT) CONTENT
        FROM WBS_AML_DETAIL
        WHERE AML_TYPE='VESSEL_NAME'
        GROUP BY AML_INFO_SEQ
    ) VESSEL_NAME
        ON E.AML_INFO_SEQ = VESSEL_NAME.AML_INFO_SEQ
    LEFT JOIN
    (
        SELECT AML_INFO_SEQ, MAX(CONTENT) CONTENT
        FROM WBS_AML_DETAIL
        WHERE AML_TYPE='FLAG_VESSEL'
        GROUP BY AML_INFO_SEQ
    ) FLAG_VESSEL
        ON E.AML_INFO_SEQ = FLAG_VESSEL.AML_INFO_SEQ
    LEFT JOIN
    (
        SELECT AML_INFO_SEQ, MAX(CONTENT) CONTENT
        FROM WBS_AML_DETAIL
        WHERE AML_TYPE='REMARK'
        GROUP BY AML_INFO_SEQ
    ) REMARK
        ON E.AML_INFO_SEQ = REMARK.AML_INFO_SEQ
    LEFT JOIN
    (
        SELECT AML_INFO_SEQ, MAX(CONTENT) CONTENT
        FROM WBS_AML_DETAIL
        WHERE AML_TYPE='TAG44A_CONTENT'
        GROUP BY AML_INFO_SEQ
    ) TAG44A_CONTENT
        ON E.AML_INFO_SEQ = TAG44A_CONTENT.AML_INFO_SEQ
    LEFT JOIN
    (
        SELECT AML_INFO_SEQ, MAX(CONTENT) CONTENT
        FROM WBS_AML_DETAIL
        WHERE AML_TYPE='TAG44E_CONTENT'
        GROUP BY AML_INFO_SEQ
    ) TAG44E_CONTENT
        ON E.AML_INFO_SEQ = TAG44E_CONTENT.AML_INFO_SEQ
    LEFT JOIN
    (
        SELECT AML_INFO_SEQ, MAX(CONTENT) CONTENT
        FROM WBS_AML_DETAIL
        WHERE AML_TYPE='TAG44F_CONTENT'
        GROUP BY AML_INFO_SEQ
    ) TAG44F_CONTENT
        ON E.AML_INFO_SEQ = TAG44F_CONTENT.AML_INFO_SEQ
    LEFT JOIN
    (
        SELECT AML_INFO_SEQ, MAX(CONTENT) CONTENT
        FROM WBS_AML_DETAIL
        WHERE AML_TYPE='TAG44B_CONTENT'
        GROUP BY AML_INFO_SEQ
    ) TAG44B_CONTENT
        ON E.AML_INFO_SEQ = TAG44B_CONTENT.AML_INFO_SEQ
    WHERE
    (
        LEFT(E.TRADE_DATE,6)
        =
        CONVERT(VARCHAR(6),DATEADD(MONTH,-1,GETDATE()),112)
        OR @@SERVERNAME='OBODS_TEST'
    )
    AND AML.FLAG='Y'
    ORDER BY E.TRADE_DATE;
    DECLARE @SQL NVARCHAR(MAX) = N'';
    WITH TBLCOLNME AS
    (
        SELECT
            C.OBJECT_ID,
            C.NAME
        FROM TEMPDB.SYS.TABLES T
        JOIN TEMPDB.SYS.COLUMNS C
            ON T.OBJECT_ID=C.OBJECT_ID
        WHERE T.NAME=N'##AMLM007_REDFLAG_REPORT_HK'
    )
    SELECT DISTINCT
        @SQL =
        STUFF
        (
            (
                SELECT CONCAT(',"',A.NAME,'"')
                FROM TBLCOLNME A
                WHERE A.OBJECT_ID=B.OBJECT_ID
                FOR XML PATH('')
            ),
            1,
            1,
            ''
        )
    FROM TBLCOLNME B;
    SET @SQL =
        CONCAT
        (
            CONCAT('SELECT ''',@SQL,''' AS COL'),
            ' UNION ALL ',
            CONCAT
            (
                N'SELECT CONCAT(',
                N'REPLACE(REPLACE(REPLACE(REPLACE(',
                REPLACE(@SQL,
                        ',',
                        N',CHAR(9),''''),CHAR(10),''''),CHAR(13),''''),'','',''，''),'','',REPLACE(REPLACE(REPLACE(REPLACE('),
                N',CHAR(9),''''),CHAR(10),''''),CHAR(13),''''),'','',''，'')',
                N') AS COL FROM ##AMLM007_REDFLAG_REPORT_HK '
            )
        );
    SET @SQL =
        CONCAT
        (
            @SQL,
            N' UNION ALL SELECT '',,,,*** End of Report ***,,,,,,,,,,,,,,,,,'' '
        );
    EXECUTE(@SQL);
END


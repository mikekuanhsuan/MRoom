;WITH Combined_List AS
(
    -- LOAN
    SELECT 'LOAN' AS SOURCE_TYPE, LON_NO AS DOC_NO, LON_CCY AS CURRENCY, LON_AMT AS AMOUNT,
           CIF_CUST_INFO_SEQ, AML_INFO_SEQ, TRADE_DATE
    FROM WBS_LON_INFO
    UNION ALL
    -- LC CREATE
    SELECT 'LC_CREATE', LC_NO, LC_NO_CCY, LC_NO_AMT,
           CIF_CUST_INFO_SEQ, AML_INFO_SEQ, TRADE_DATE
    FROM WBS_IMP_LC
    UNION ALL
    -- LC AMEND
    SELECT 'LC_AMEND', LC_NO, LC_NO_CCY, NEW_AMT,
           CIF_CUST_INFO_SEQ, AML_INFO_SEQ, TRADE_DATE
    FROM WBS_IMP_LC
    UNION ALL
    -- SGED
    SELECT 'SGED', SGED_NO, SGED_CCY, SGED_AMT,
           CIF_CUST_INFO_SEQ, AML_INFO_SEQ, TRADE_DATE
    FROM WBS_IMP_SGED
    UNION ALL
    -- IB
    SELECT 'IB', IB_NO, BILL_CCY, BILL_AMT1,
           CIF_CUST_INFO_SEQ, AML_INFO_SEQ, TRADE_DATE
    FROM WBS_IMP_IB
    UNION ALL
    -- IC
    SELECT 'IC', IC_NO, BILL_CCY, BILL_AMT,
           CIF_CUST_INFO_SEQ, AML_INFO_SEQ, TRADE_DATE
    FROM WBS_IMP_IC
    UNION ALL
    -- LA
    SELECT 'LA', LA_NO, LC_CCY, LC_AMT,
           CIF_CUST_INFO_SEQ, AML_INFO_SEQ, TRADE_DATE
    FROM WBS_EXP_LA_INFO
    UNION ALL
    -- LT
    SELECT 'LT', LT_NO, LC_CCY, LT_AMT,
           CIF_CUST_INFO_SEQ, AML_INFO_SEQ, TRADE_DATE
    FROM WBS_EXP_LT_INFO
    UNION ALL
    -- NEGO
    SELECT 'NEGO', NEGO_NO, BILL_CCY, BILL_AMT,
           CIF_CUST_INFO_SEQ, AML_INFO_SEQ, TRADE_DATE
    FROM WBS_EXP_NEGO_INFO
    UNION ALL
    -- RENEGO
    SELECT 'RENEGO', REF_NO, BILL_CCY, BILL_AMT,
           CIF_CUST_INFO_SEQ, AML_INFO_SEQ, TRADE_DATE
    FROM WBS_EXP_RE_NEGO_INFO
    UNION ALL
    -- OC
    SELECT 'OC', OC_NO, BILL_CCY, BILL_AMT,
           CIF_CUST_INFO_SEQ, AML_INFO_SEQ, TRADE_DATE
    FROM WBS_EXP_OC_INFO
)
SELECT COUNT(*)
FROM
(
    SELECT
        E.AML_INFO_SEQ
    FROM Combined_List E
    LEFT JOIN
    (
        SELECT
            AML_INFO_SEQ,
            MAX(FLAG) AS FLAG,
            MAX(FUN_CODE) AS FUN_CODE,
            MAX(CONTENT) AS CONTENT
        FROM WBS_AML_DETAIL
        WHERE AML_TYPE='RED_FLAG'
        GROUP BY AML_INFO_SEQ
    ) AML
        ON E.AML_INFO_SEQ = AML.AML_INFO_SEQ
    LEFT JOIN
    (
        SELECT
            AML_INFO_SEQ,
            MAX(CONTENT) AS CONTENT
        FROM WBS_AML_DETAIL
        WHERE AML_TYPE='VESSEL_NAME'
        GROUP BY AML_INFO_SEQ
    ) VESSEL_NAME
        ON E.AML_INFO_SEQ = VESSEL_NAME.AML_INFO_SEQ
    LEFT JOIN
    (
        SELECT
            AML_INFO_SEQ,
            MAX(CONTENT) AS CONTENT
        FROM WBS_AML_DETAIL
        WHERE AML_TYPE='FLAG_VESSEL'
        GROUP BY AML_INFO_SEQ
    ) FLAG_VESSEL
        ON E.AML_INFO_SEQ = FLAG_VESSEL.AML_INFO_SEQ
    LEFT JOIN
    (
        SELECT
            AML_INFO_SEQ,
            MAX(CONTENT) AS CONTENT
        FROM WBS_AML_DETAIL
        WHERE AML_TYPE='GOODSCODE'
        GROUP BY AML_INFO_SEQ
    ) GOODSCODE
        ON E.AML_INFO_SEQ = GOODSCODE.AML_INFO_SEQ
    LEFT JOIN
    (
        SELECT
            AML_INFO_SEQ,
            MAX(CONTENT) AS CONTENT
        FROM WBS_AML_DETAIL
        WHERE AML_TYPE='MERCHANDISE'
        GROUP BY AML_INFO_SEQ
    ) MERCHANDISE
        ON E.AML_INFO_SEQ = MERCHANDISE.AML_INFO_SEQ
    LEFT JOIN
    (
        SELECT
            AML_INFO_SEQ,
            MAX(CONTENT) AS CONTENT
        FROM WBS_AML_DETAIL
        WHERE AML_TYPE='REMARK'
        GROUP BY AML_INFO_SEQ
    ) REMARK
        ON E.AML_INFO_SEQ = REMARK.AML_INFO_SEQ
    LEFT JOIN
    (
        SELECT
            AML_INFO_SEQ,
            MAX(CONTENT) AS CONTENT
        FROM WBS_AML_DETAIL
        WHERE AML_TYPE='TAG44A_CONTENT'
        GROUP BY AML_INFO_SEQ
    ) TAG44A
        ON E.AML_INFO_SEQ = TAG44A.AML_INFO_SEQ
    LEFT JOIN
    (
        SELECT
            AML_INFO_SEQ,
            MAX(CONTENT) AS CONTENT
        FROM WBS_AML_DETAIL
        WHERE AML_TYPE='TAG44E_CONTENT'
        GROUP BY AML_INFO_SEQ
    ) TAG44E
        ON E.AML_INFO_SEQ = TAG44E.AML_INFO_SEQ
    LEFT JOIN
    (
        SELECT
            AML_INFO_SEQ,
            MAX(CONTENT) AS CONTENT
        FROM WBS_AML_DETAIL
        WHERE AML_TYPE='TAG44F_CONTENT'
        GROUP BY AML_INFO_SEQ
    ) TAG44F
        ON E.AML_INFO_SEQ = TAG44F.AML_INFO_SEQ
    LEFT JOIN
    (
        SELECT
            AML_INFO_SEQ,
            MAX(CONTENT) AS CONTENT
        FROM WBS_AML_DETAIL
        WHERE AML_TYPE='TAG44B_CONTENT'
        GROUP BY AML_INFO_SEQ
    ) TAG44B
        ON E.AML_INFO_SEQ = TAG44B.AML_INFO_SEQ
    WHERE AML.FLAG='Y'
) A;


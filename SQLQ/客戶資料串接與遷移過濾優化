Private Function GetBranchInClause(ws As Worksheet) As String

    Dim lastRow As Long
    Dim cell As Range
    Dim arr As Object

    Set arr = CreateObject("System.Collections.ArrayList")

    lastRow = ws.Cells(ws.Rows.Count, "A").End(xlUp).Row

    For Each cell In ws.Range("A2:A" & lastRow)

        If Trim(cell.Value) <> "" Then

            arr.Add "'" & Replace(Trim(cell.Value), "_", "") & "'"

        End If

    Next cell

    GetBranchInClause = Join(arr.ToArray(), ", ")

End Function
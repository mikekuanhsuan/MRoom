---------------------------------------------------
-- 2. UNPIVOT
---------------------------------------------------
SELECT
    月份,
    col,
    CAST(val AS DECIMAL(18,4)) AS val
INTO #Base
FROM #Raw
UNPIVOT (
    val FOR col IN (_0001, _0002)
) u;

---------------------------------------------------
-- 3. 分需求 / 供給 + 排序
---------------------------------------------------
WITH CTE AS (
    SELECT *,
        ROW_NUMBER() OVER (PARTITION BY col ORDER BY 月份) AS rn
    FROM #Base
),

Demand AS (
    SELECT 
        col,
        月份 AS DemandMonth,
        val AS DemandQty,
        rn,
        SUM(val) OVER (PARTITION BY col ORDER BY rn) AS CumDemand
    FROM CTE
    WHERE val > 0
),

Supply AS (
    SELECT 
        col,
        月份 AS SupplyMonth,
        ABS(val) AS SupplyQty,
        rn,
        SUM(ABS(val)) OVER (PARTITION BY col ORDER BY rn) AS CumSupply
    FROM CTE
    WHERE val < 0
),

---------------------------------------------------
-- 4. 區間交集（核心）
---------------------------------------------------
MatchTable AS (
    SELECT 
        d.col,
        d.DemandMonth,
        s.SupplyMonth,

        CASE 
            WHEN 
                (CASE WHEN d.CumDemand < s.CumSupply THEN d.CumDemand ELSE s.CumSupply END)
                -
                (CASE 
                    WHEN (d.CumDemand - d.DemandQty) > (s.CumSupply - s.SupplyQty) 
                    THEN (d.CumDemand - d.DemandQty)
                    ELSE (s.CumSupply - s.SupplyQty)
                 END) > 0
            THEN 
                (CASE WHEN d.CumDemand < s.CumSupply THEN d.CumDemand ELSE s.CumSupply END)
                -
                (CASE 
                    WHEN (d.CumDemand - d.DemandQty) > (s.CumSupply - s.SupplyQty) 
                    THEN (d.CumDemand - d.DemandQty)
                    ELSE (s.CumSupply - s.SupplyQty)
                 END)
            ELSE 0
        END AS AllocQty

    FROM Demand d
    JOIN Supply s
        ON d.col = s.col
)

---------------------------------------------------
-- 5. 最終結果
---------------------------------------------------
SELECT 
    DemandMonth AS 需求月份,
    SupplyMonth AS 供給月份,
    AllocQty AS 分配量,
    col AS 列標籤
FROM MatchTable
WHERE AllocQty > 0
ORDER BY col, DemandMonth, SupplyMonth;
SELECT 
    a.customerno,
	c.PEPBitwiseCode,
    CASE WHEN c.PEPBitwiseCode & 1   = 1   THEN 'Y' ELSE 'N' END AS BlackList,
    CASE WHEN c.PEPBitwiseCode & 2   = 2   THEN 'Y' ELSE 'N' END AS PEP,
    CASE WHEN c.PEPBitwiseCode & 4   = 4   THEN 'Y' ELSE 'N' END AS NN,
    CASE WHEN c.PEPBitwiseCode & 8   = 8   THEN 'Y' ELSE 'N' END AS ForeignPEP,
    CASE WHEN c.PEPBitwiseCode & 16  = 16  THEN 'Y' ELSE 'N' END AS LocalPEP,
    CASE WHEN c.PEPBitwiseCode & 32  = 32  THEN 'Y' ELSE 'N' END AS ForeignOrgPEP,
    CASE WHEN c.PEPBitwiseCode & 64  = 64  THEN 'Y' ELSE 'N' END AS EfPEP,
    CASE WHEN c.PEPBitwiseCode & 128 = 128 THEN 'Y' ELSE 'N' END AS CustRPIsPEP
FROM BSA_SUB_CUST_FACT a
JOIN PB_CUSTOMER_FACT b 
    ON b.cif_KEY = a.cif_KEY 
JOIN BSA_SUB_CUST_FACT_Extension c 
    ON c.cif_KEY = a.cif_KEY 
JOIN (
      SELECT TS_CUST_ID FROM BANCS_SK_CUST_INFO WHERE CUST_RE_NO_FLG = '1'
       EXCEPT
       SELECT TS_CUST_ID FROM BANCS_SK_CUST_INFO WHERE CUST_RE_NO_FLG IN ('2', '3')
) d
    ON a.customerno = d.TS_CUST_ID
WHERE ISNULL(c.PEPBitwiseCode,'0')<>'0'



-- 3. 分別準備需求和供給表，並加上行號以供排序
SELECT 
    月份,
    col,
    val,
    ROW_NUMBER() OVER(PARTITION BY col ORDER BY 月份) AS rn
INTO #Demand
FROM #Base
WHERE val > 0;

SELECT 
    月份,
    col,
    -val AS supply,
    ROW_NUMBER() OVER(PARTITION BY col ORDER BY 月份) AS rn
INTO #Supply
FROM #Base
WHERE val < 0;

-- 4. 使用遞迴 CTE 模擬 Python 的分配邏輯
WITH RecursiveAllocation AS (
    -- Anchor member: 處理每個欄位的初始狀態
    SELECT
        d.col,
        d.月份 AS 需求月份,
        s.月份 AS 供給月份,
        1 AS d_rn, -- 需求方的行號
        1 AS s_rn, -- 供給方的行號
        IIF(d.val < s.supply, d.val, s.supply) AS 分配量,
        d.val - IIF(d.val < s.supply, d.val, s.supply) AS remaining_demand,
        s.supply - IIF(d.val < s.supply, d.val, s.supply) AS remaining_supply
    FROM #Demand d
    JOIN #Supply s ON d.col = s.col AND d.rn = 1 AND s.rn = 1

    UNION ALL

    -- Recursive member: 根據上一輪的剩餘量進行下一次分配
    SELECT
        prev.col,
        next_d.月份,
        next_s.月份,
        CASE WHEN prev.remaining_demand = 0 THEN prev.d_rn + 1 ELSE prev.d_rn END,
        CASE WHEN prev.remaining_supply = 0 THEN prev.s_rn + 1 ELSE prev.s_rn END,
        IIF(next_d.val < next_s.supply, next_d.val, next_s.supply),
        next_d.val - IIF(next_d.val < next_s.supply, next_d.val, next_s.supply),
        next_s.supply - IIF(next_d.val < next_s.supply, next_d.val, next_s.supply)
    FROM RecursiveAllocation prev
    -- 根據上一輪的結果決定下一輪要 JOIN 的需求和供給
    JOIN #Demand next_d ON prev.col = next_d.col AND next_d.rn = (CASE WHEN prev.remaining_demand = 0 THEN prev.d_rn + 1 ELSE prev.d_rn END)
    JOIN #Supply next_s ON prev.col = next_s.col AND next_s.rn = (CASE WHEN prev.remaining_supply = 0 THEN prev.s_rn + 1 ELSE prev.s_rn END)
    -- 只有在還有剩餘量時才繼續遞迴
    WHERE prev.remaining_demand > 0 OR prev.remaining_supply > 0
)
-- 5. 輸出最終結果
SELECT 
    需求月份,
    供給月份,
    分配量,
    col AS 欄位
FROM RecursiveAllocation
WHERE 分配量 > 0 -- 只顯示有實際分配的記錄
ORDER BY 欄位, 需求月份, 供給月份
OPTION (MAXRECURSION 0); -- 允許無限遞迴，防止因資料量大而中斷

-- 6. 產生總結報表
WITH RecursiveAllocation AS (
    SELECT
        d.col,
        d.月份 AS 需求月份,
        s.月份 AS 供給月份,
        1 AS d_rn,
        1 AS s_rn,
        IIF(d.val < s.supply, d.val, s.supply) AS 分配量,
        d.val - IIF(d.val < s.supply, d.val, s.supply) AS remaining_demand,
        s.supply - IIF(d.val < s.supply, d.val, s.supply) AS remaining_supply
    FROM #Demand d
    JOIN #Supply s ON d.col = s.col AND d.rn = 1 AND s.rn = 1
    UNION ALL
    SELECT
        prev.col,
        next_d.月份,
        next_s.月份,
        CASE WHEN prev.remaining_demand = 0 THEN prev.d_rn + 1 ELSE prev.d_rn END,
        CASE WHEN prev.remaining_supply = 0 THEN prev.s_rn + 1 ELSE prev.s_rn END,
        IIF(next_d.val < next_s.supply, next_d.val, next_s.supply),
        next_d.val - IIF(next_d.val < next_s.supply, next_d.val, next_s.supply),
        next_s.supply - IIF(next_d.val < next_s.supply, next_d.val, next_s.supply)
    FROM RecursiveAllocation prev
    JOIN #Demand next_d ON prev.col = next_d.col AND next_d.rn = (CASE WHEN prev.remaining_demand = 0 THEN prev.d_rn + 1 ELSE prev.d_rn END)
    JOIN #Supply next_s ON prev.col = next_s.col AND next_s.rn = (CASE WHEN prev.remaining_supply = 0 THEN prev.s_rn + 1 ELSE prev.s_rn END)
    WHERE prev.remaining_demand > 0 OR prev.remaining_supply > 0
)
SELECT
    col AS 欄位,
    SUM(分配量) AS 總分配量
FROM RecursiveAllocation
GROUP BY col
ORDER BY 欄位;


-- 純台新
-- 預期結果，風險等級不變。
WITH PURE_TS AS
(
    SELECT CustomerNo
    FROM VERIFY..BSA_SUB_CUST_FACT
    EXCEPT
    SELECT a.CustomerNo
    FROM BSA_SUB_CUST_FACT a
    JOIN CIF_Migrate_Mapping_TEMP b
        ON a.cif_key = b.NEW_CIF_KEY
)
SELECT
    p.CustomerNo,
    v.HIGHRISK AS VERIFY_HIGHRISK,
    b.HIGHRISK AS BSA_HIGHRISK,
    CASE
        WHEN ISNULL(v.HIGHRISK,0) = ISNULL(b.HIGHRISK,0)
            THEN 'Same'
        ELSE 'Different'
    END AS CompareResult
FROM PURE_TS p
LEFT JOIN VERIFY..BSA_SUB_CUST_FACT v    ON p.CustomerNo = v.CustomerNo
LEFT JOIN BSA_SUB_CUST_FACT b    ON p.CustomerNo = b.CustomerNo
ORDER BY p.CustomerNo;


-- 驗證同一個 CustomerNo 的 HIGHRISK 是否不一致
WITH PURE_TS AS
(
    SELECT CustomerNo
    FROM VERIFY..BSA_SUB_CUST_FACT
    EXCEPT
    SELECT a.CustomerNo
    FROM BSA_SUB_CUST_FACT a
    JOIN CIF_Migrate_Mapping_TEMP b
        ON a.cif_key = b.NEW_CIF_KEY
)
SELECT
    p.CustomerNo,
    v.HIGHRISK AS VERIFY_HIGHRISK,
    b.HIGHRISK AS BSA_HIGHRISK
FROM PURE_TS p
LEFT JOIN VERIFY..BSA_SUB_CUST_FACT v    ON p.CustomerNo = v.CustomerNo
LEFT JOIN BSA_SUB_CUST_FACT b    ON p.CustomerNo = b.CustomerNo
WHERE ISNULL(v.HIGHRISK,0) <> ISNULL(b.HIGHRISK,0)
ORDER BY p.CustomerNo;

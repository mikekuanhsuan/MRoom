WITH FirstResult AS (
    SELECT 
        a.customerno,
        a.HIGHRISK
    FROM VERIFY..BSA_SUB_CUST_FACT a
    JOIN VERIFY..PB_CUSTOMER_FACT b 
        ON b.cif_KEY = a.cif_KEY 
    JOIN (
        SELECT TS_CUST_ID
        FROM BANCS_SK_CUST_INFO
        GROUP BY TS_CUST_ID
        HAVING 
            COUNT(*) > 1
            AND SUM(CASE WHEN CUST_RE_NO_FLG = '1' THEN 1 ELSE 0 END) > 0
            AND SUM(CASE WHEN CUST_RE_NO_FLG IN ('2','3') THEN 1 ELSE 0 END) = 0
    ) d
        ON a.customerno = d.TS_CUST_ID
)

SELECT 
    f.customerno,
    f.HIGHRISK AS First_HIGHRISK,
    b.HIGHRISK AS Second_HIGHRISK
FROM FirstResult f
JOIN BSA_SUB_CUST_FACT b
    ON f.customerno = b.customerno
WHERE f.HIGHRISK <> b.HIGHRISK;


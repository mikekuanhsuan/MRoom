-- 4. 嚴格定義需求和供給表 (使用 LEFT 取出年月份比對)
SELECT 
    月份, col, val,
    ROW_NUMBER() OVER(PARTITION BY col ORDER BY 月份) AS rn
INTO #Demand
FROM #Base
WHERE LEFT(月份, 6) <= '202705' 
  AND val > 0;

SELECT 
    月份, col, -val AS supply,
    ROW_NUMBER() OVER(PARTITION BY col ORDER BY 月份) AS rn
INTO #Supply
FROM #Base
WHERE LEFT(月份, 6) >= '202706' 
  AND val < 0;

-- 5. 遞迴 CTE 計算分配結果
WITH RecursiveAllocation AS (
    -- Anchor member (加入 CAST 鎖死 DECIMAL(18,4))
    SELECT
        d.col,
        d.月份 AS 需求月份,
        s.月份 AS 供給月份,
        d.rn AS d_rn,
        s.rn AS s_rn,
        CAST(IIF(d.val < s.supply, d.val, s.supply) AS DECIMAL(18,4)) AS 分配量,
        CAST(IIF(d.val < s.supply, 0, d.val - s.supply) AS DECIMAL(18,4)) AS remaining_demand,
        CAST(IIF(d.val < s.supply, s.supply - d.val, 0) AS DECIMAL(18,4)) AS remaining_supply
    FROM #Demand d
    JOIN #Supply s ON d.col = s.col AND d.rn = 1 AND s.rn = 1

    UNION ALL

    -- Recursive member (同樣加入 CAST 鎖死)
    SELECT
        prev.col,
        next_d.月份,
        next_s.月份,
        next_d.rn AS d_rn,
        next_s.rn AS s_rn,
        
        CAST(
            IIF(
                IIF(prev.remaining_demand > 0, prev.remaining_demand, next_d.val) < IIF(prev.remaining_supply > 0, prev.remaining_supply, next_s.supply),
                IIF(prev.remaining_demand > 0, prev.remaining_demand, next_d.val),
                IIF(prev.remaining_supply > 0, prev.remaining_supply, next_s.supply)
            ) 
        AS DECIMAL(18,4)) AS 分配量,
        
        CAST(
            IIF(prev.remaining_demand > 0, prev.remaining_demand, next_d.val) - 
            IIF(
                IIF(prev.remaining_demand > 0, prev.remaining_demand, next_d.val) < IIF(prev.remaining_supply > 0, prev.remaining_supply, next_s.supply),
                IIF(prev.remaining_demand > 0, prev.remaining_demand, next_d.val),
                IIF(prev.remaining_supply > 0, prev.remaining_supply, next_s.supply)
            ) 
        AS DECIMAL(18,4)) AS remaining_demand,
        
        CAST(
            IIF(prev.remaining_supply > 0, prev.remaining_supply, next_s.supply) - 
            IIF(
                IIF(prev.remaining_demand > 0, prev.remaining_demand, next_d.val) < IIF(prev.remaining_supply > 0, prev.remaining_supply, next_s.supply),
                IIF(prev.remaining_demand > 0, prev.remaining_demand, next_d.val),
                IIF(prev.remaining_supply > 0, prev.remaining_supply, next_s.supply)
            ) 
        AS DECIMAL(18,4)) AS remaining_supply

    FROM RecursiveAllocation prev
    JOIN #Demand next_d ON prev.col = next_d.col AND next_d.rn = IIF(prev.remaining_demand = 0, prev.d_rn + 1, prev.d_rn)
    JOIN #Supply next_s ON prev.col = next_s.col AND next_s.rn = IIF(prev.remaining_supply = 0, prev.s_rn + 1, prev.s_rn)
)

-- 將結果存入臨時表 #FinalResult
SELECT 
    需求月份,
    供給月份,
    分配量,
    col AS 列標籤
INTO #FinalResult
FROM RecursiveAllocation
WHERE 分配量 > 0
OPTION (MAXRECURSION 0);


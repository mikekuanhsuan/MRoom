WITH RISK_DATA AS
(
    SELECT
        s.TS_CUST_ID,
        s.CUST_RE_NO_FLG,
        n.HIGHRISK,
        CASE n.HIGHRISK
            WHEN 'L' THEN 1
            WHEN 'M' THEN 2
            WHEN 'H' THEN 3
        END AS RISK_LEVEL
    FROM BANCS_SK_CUST_INFO s
    JOIN Cust_NP_Migrate_buffer n
        ON s.SK_CUST_ID = n.CustomerNo
)
SELECT
    f2.TS_CUST_ID,
    f2.HIGHRISK AS FLAG2_RISK,
    f1.HIGHRISK AS FLAG1_RISK
FROM RISK_DATA f2
JOIN RISK_DATA f1
    ON f2.TS_CUST_ID = f1.TS_CUST_ID
WHERE f2.CUST_RE_NO_FLG = 2
  AND f1.CUST_RE_NO_FLG = 1
  AND f2.RISK_LEVEL < f1.RISK_LEVEL;
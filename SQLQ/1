ALTER PROCEDURE [dbo].[SP_AMLM007_REDFLAG_REPORT_HK]
AS
BEGIN
    SET NOCOUNT OFF;
    EXECUTE(N'DROP TABLE IF EXISTS ##AMLM007_REDFLAG_REPORT_HK');

    -- 1. Combine all source tables
    ;WITH Combined_List AS (
        -- LOAN
        SELECT 'LOAN' AS SOURCE_TYPE, LON_NO AS DOC_NO, LON_CCY AS CURRENCY, LON_AMT AS AMOUNT, CIF_CUST_INFO_SEQ, AML_INFO_SEQ, TRADE_DATE FROM WBS_LON_INFO
        UNION ALL
        -- LC CREATE
        SELECT 'LC_CREATE', LC_NO, LC_NO_CCY, LC_NO_AMT, CIF_CUST_INFO_SEQ, AML_INFO_SEQ, TRADE_DATE FROM WBS_IMP_LC
        UNION ALL
        -- LC AMEND
        SELECT 'LC_AMEND', LC_NO, LC_NO_CCY, NEW_AMT, CIF_CUST_INFO_SEQ, AML_INFO_SEQ, TRADE_DATE FROM WBS_IMP_LC
        UNION ALL
        -- SGED
        SELECT 'SGED', SGED_NO, SGED_CCY, SGED_AMT, CIF_CUST_INFO_SEQ, AML_INFO_SEQ, TRADE_DATE FROM WBS_IMP_SGED
        UNION ALL
        -- IB
        SELECT 'IB', IB_NO, BILL_CCY, BILL_AMT1, CIF_CUST_INFO_SEQ, AML_INFO_SEQ, TRADE_DATE FROM WBS_IMP_IB
        UNION ALL
        -- IC
        SELECT 'IC', IC_NO, BILL_CCY, BILL_AMT, CIF_CUST_INFO_SEQ, AML_INFO_SEQ, TRADE_DATE FROM WBS_IMP_IC
        UNION ALL
        -- LA
        SELECT 'LA', LA_NO, LC_CCY, LC_AMT, CIF_CUST_INFO_SEQ, AML_INFO_SEQ, TRADE_DATE FROM WBS_EXP_LA_INFO
        UNION ALL
        -- LT
        SELECT 'LT', LT_NO, LC_CCY, LT_AMT, CIF_CUST_INFO_SEQ, AML_INFO_SEQ, TRADE_DATE FROM WBS_EXP_LT_INFO
        UNION ALL
        -- NEGO
        SELECT 'NEGO', NEGO_NO, BILL_CCY, BILL_AMT, CIF_CUST_INFO_SEQ, AML_INFO_SEQ, TRADE_DATE FROM WBS_EXP_NEGO_INFO
        UNION ALL
        -- RENEGO
        SELECT 'RENEGO', REF_NO, BILL_CCY, BILL_AMT, CIF_CUST_INFO_SEQ, AML_INFO_SEQ, TRADE_DATE FROM WBS_EXP_RE_NEGO_INFO
        UNION ALL
        -- OC
        SELECT 'OC', OC_NO, BILL_CCY, BILL_AMT, CIF_CUST_INFO_SEQ, AML_INFO_SEQ, TRADE_DATE FROM WBS_EXP_OC_INFO
    )

    -- 2. Output to temp table
    SELECT
        E.SOURCE_TYPE, E.DOC_NO, E.CURRENCY, E.AMOUNT, E.TRADE_DATE,
        '_' + ISNULL(C.CUSTOMER_ID,'') AS CUSTOMER_ID,
        F.FUNC_CODE AS Function_Code,
        F.FUNC_NAME AS Function_Name, 
        AML.FLAG AS FLAG, 
        AML.CONTENT AS FLAG_CONTENT, 
        GOODSCODE.CONTENT AS GOODSCODE,
        MERCHANDISE.CONTENT AS MERCHANDISE,
        VESSEL_NAME.CONTENT AS VESSEL_NAME,
        FLAG_VESSEL.CONTENT AS FLAG_VESSEL,
        REMARK.CONTENT AS REMARK,
        TAG44A_CONTENT.CONTENT AS TAG44A_CONTENT,  -- PORT_OF_LOADING
        TAG44E_CONTENT.CONTENT AS TAG44E_CONTENT,  -- PORT_OF_DISCHARGE
        TAG44F_CONTENT.CONTENT AS TAG44F_CONTENT,  -- PORT_OF_TRANSSHIPMENT
        TAG44B_CONTENT.CONTENT AS TAG44B_CONTENT,  -- FINAL_DESTINATION
        E.AML_INFO_SEQ
    INTO ##AMLM007_REDFLAG_REPORT_HK
    FROM Combined_List E
    LEFT JOIN WBS_CIF_CUST_INFO C ON E.CIF_CUST_INFO_SEQ = C.CIF_CUST_INFO_SEQ
    LEFT JOIN (
        SELECT AML_INFO_SEQ, MAX(FLAG) AS FLAG, MAX(FUN_CODE) AS FUN_CODE, MAX(CONTENT) AS CONTENT
        FROM WBS_AML_DETAIL WHERE AML_TYPE='RED_FLAG' GROUP BY AML_INFO_SEQ
    ) AML ON E.AML_INFO_SEQ = AML.AML_INFO_SEQ
    LEFT JOIN WBS_RAA_FUNC_INFO F ON AML.FUN_CODE = F.FUNC_CODE
    LEFT JOIN (
        SELECT AML_INFO_SEQ, MAX(CONTENT) CONTENT FROM WBS_AML_DETAIL WHERE AML_TYPE='GOODSCODE' GROUP BY AML_INFO_SEQ
    ) GOODSCODE ON E.AML_INFO_SEQ = GOODSCODE.AML_INFO_SEQ
    LEFT JOIN (
        SELECT AML_INFO_SEQ, MAX(CONTENT) CONTENT FROM WBS_AML_DETAIL WHERE AML_TYPE='MERCHANDISE' GROUP BY AML_INFO_SEQ
    ) MERCHANDISE ON E.AML_INFO_SEQ = MERCHANDISE.AML_INFO_SEQ
    LEFT JOIN (
        SELECT AML_INFO_SEQ, STRING_AGG(CAST(CONTENT AS NVARCHAR(MAX)), ',') AS CONTENT FROM WBS_AML_DETAIL WHERE AML_TYPE='VESSEL_NAME' GROUP BY AML_INFO_SEQ
    ) VESSEL_NAME ON E.AML_INFO_SEQ = VESSEL_NAME.AML_INFO_SEQ
    LEFT JOIN (
        SELECT AML_INFO_SEQ, MAX(CONTENT) CONTENT FROM WBS_AML_DETAIL WHERE AML_TYPE='FLAG_VESSEL' GROUP BY AML_INFO_SEQ
    ) FLAG_VESSEL ON E.AML_INFO_SEQ = FLAG_VESSEL.AML_INFO_SEQ
    LEFT JOIN (
        SELECT AML_INFO_SEQ, MAX(CONTENT) CONTENT FROM WBS_AML_DETAIL WHERE AML_TYPE='REMARK' GROUP BY AML_INFO_SEQ
    ) REMARK ON E.AML_INFO_SEQ = REMARK.AML_INFO_SEQ
    LEFT JOIN (
        SELECT AML_INFO_SEQ, MAX(CONTENT) CONTENT FROM WBS_AML_DETAIL WHERE AML_TYPE='TAG44A_CONTENT' GROUP BY AML_INFO_SEQ
    ) TAG44A_CONTENT ON E.AML_INFO_SEQ = TAG44A_CONTENT.AML_INFO_SEQ
    LEFT JOIN (
        SELECT AML_INFO_SEQ, MAX(CONTENT) CONTENT FROM WBS_AML_DETAIL WHERE AML_TYPE='TAG44E_CONTENT' GROUP BY AML_INFO_SEQ
    ) TAG44E_CONTENT ON E.AML_INFO_SEQ = TAG44E_CONTENT.AML_INFO_SEQ
    LEFT JOIN (
        SELECT AML_INFO_SEQ, MAX(CONTENT) CONTENT FROM WBS_AML_DETAIL WHERE AML_TYPE='TAG44F_CONTENT' GROUP BY AML_INFO_SEQ
    ) TAG44F_CONTENT ON E.AML_INFO_SEQ = TAG44F_CONTENT.AML_INFO_SEQ
    LEFT JOIN (
        SELECT AML_INFO_SEQ, MAX(CONTENT) CONTENT FROM WBS_AML_DETAIL WHERE AML_TYPE='TAG44B_CONTENT' GROUP BY AML_INFO_SEQ
    ) TAG44B_CONTENT ON E.AML_INFO_SEQ = TAG44B_CONTENT.AML_INFO_SEQ
    WHERE (
        LEFT(E.TRADE_DATE,6) = CONVERT(VARCHAR(6),DATEADD(MONTH,-1,GETDATE()),112)
        --OR @@SERVERNAME='OBODS_TEST'
    )
    AND AML.FLAG='Y'
    ORDER BY E.TRADE_DATE;

    -- 3. 動態產生欄位名稱
    DECLARE @SQL NVARCHAR(MAX) = N'';
    WITH TBLCOLNME AS (
        SELECT C.OBJECT_ID, C.NAME
        FROM TEMPDB.SYS.TABLES T
        JOIN TEMPDB.SYS.COLUMNS C ON T.OBJECT_ID=C.OBJECT_ID
        WHERE T.NAME=N'##AMLM007_REDFLAG_REPORT_HK'
    )
    SELECT DISTINCT
        @SQL = STUFF((
            SELECT CONCAT(',"',A.NAME,'"')
            FROM TBLCOLNME A
            WHERE A.OBJECT_ID=B.OBJECT_ID
            FOR XML PATH('')
        ), 1, 1, '')
    FROM TBLCOLNME B;

    -- 4. 動態產生查詢語法
    SET @SQL = CONCAT(
        CONCAT('SELECT ''',@SQL,''' AS COL'),
        ' UNION ALL ',
        CONCAT(
            N'SELECT CONCAT(',
            N'REPLACE(REPLACE(REPLACE(REPLACE(',
            REPLACE(@SQL,',',N',CHAR(9),''''),CHAR(10),''''),CHAR(13),''''),'','',''，''),'','',REPLACE(REPLACE(REPLACE(REPLACE('),
            N',CHAR(9),''''),CHAR(10),''''),CHAR(13),''''),'','',''，'')',
            N') AS COL FROM ##AMLM007_REDFLAG_REPORT_HK '
        )
    );
    SET @SQL = CONCAT(
        @SQL,
        N' UNION ALL SELECT '',,,,*** End of Report ***,,,,,,,,,,,,,,,,,'' '
    );
    EXECUTE(@SQL);
END

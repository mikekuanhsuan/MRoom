你現在是在驗證：

VERIFY..BSA_SUB_CUST_FACT 有，但實際資轉後 BSA_SUB_CUST_FACT 沒有的客戶，

確認他們的 IsSARFiled 是否一致（或是否被錯誤修改）。

其實可以直接做成一張比對表：

WITH MISSING_CUST AS
(
    SELECT CustomerNo
    FROM VERIFY..BSA_SUB_CUST_FACT
    EXCEPT
    SELECT a.CustomerNo
    FROM BSA_SUB_CUST_FACT a
    JOIN CIF_Migrate_Mapping_TEMP b
        ON a.cif_key = b.NEW_CIF_KEY
)
SELECT
    v.CustomerNo,
    v.IsSARFiled AS VERIFY_IsSARFiled,
    b.IsSARFiled AS BSA_IsSARFiled,
    CASE
        WHEN ISNULL(v.IsSARFiled,0) = ISNULL(b.IsSARFiled,0)
            THEN 'Same'
        ELSE 'Different'
    END AS CompareResult
FROM MISSING_CUST m
LEFT JOIN VERIFY..BSA_SUB_CUST_FACT v
    ON m.CustomerNo = v.CustomerNo
LEFT JOIN BSA_SUB_CUST_FACT b
    ON m.CustomerNo = b.CustomerNo
ORDER BY m.CustomerNo;


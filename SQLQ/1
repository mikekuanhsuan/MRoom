如果你的意思是：

1. 先找出 只存在 CUST_RE_NO_FLG='1'，但不存在於 2、3 的 TS_CUST_ID
2. 再確認這些 TS_CUST_ID 是否同時存在於
    * BSA_SUB_CUST_FACT
    * VERIFY..BSA_SUB_CUST_FACT

可以這樣寫：

WITH CUST_LIST AS
(
    SELECT TS_CUST_ID
    FROM BANCS_SK_CUST_INFO
    WHERE CUST_RE_NO_FLG = '1'
    EXCEPT
    SELECT TS_CUST_ID
    FROM BANCS_SK_CUST_INFO
    WHERE CUST_RE_NO_FLG IN ('2','3')
)
SELECT
    c.TS_CUST_ID,
    b.CustomerNo AS BSA_CustomerNo,
    v.CustomerNo AS VERIFY_CustomerNo
FROM CUST_LIST c
LEFT JOIN BSA_SUB_CUST_FACT b
    ON c.TS_CUST_ID = b.CustomerNo
LEFT JOIN VERIFY..BSA_SUB_CUST_FACT v
    ON c.TS_CUST_ID = v.CustomerNo;

⸻

如果只是要看 有存在於兩邊的客戶：

WITH CUST_LIST AS
(
    SELECT TS_CUST_ID
    FROM BANCS_SK_CUST_INFO
    WHERE CUST_RE_NO_FLG = '1'
    EXCEPT
    SELECT TS_CUST_ID
    FROM BANCS_SK_CUST_INFO
    WHERE CUST_RE_NO_FLG IN ('2','3')
)
SELECT DISTINCT
       c.TS_CUST_ID
FROM CUST_LIST c
INNER JOIN BSA_SUB_CUST_FACT b
    ON c.TS_CUST_ID = b.CustomerNo
INNER JOIN VERIFY..BSA_SUB_CUST_FACT v
    ON c.TS_CUST_ID = v.CustomerNo;


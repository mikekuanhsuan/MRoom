-- 如果臨時表已存在，則先刪除
IF OBJECT_ID('tempdb..#Raw') IS NOT NULL DROP TABLE #Raw;
IF OBJECT_ID('tempdb..#Base') IS NOT NULL DROP TABLE #Base;

-- 1. 建立 Raw
CREATE TABLE #Raw (
    月份 VARCHAR(20),
    _0001 FLOAT,
    _0002 FLOAT
);


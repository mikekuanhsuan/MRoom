SELECT
v.CustomerNo,
v.HIGHRISK AS VERIFY_HIGHRISK,
b.HIGHRISK AS BSA_HIGHRISK,
CASE
    WHEN ISNULL(v.HIGHRISK,0) = ISNULL(b.HIGHRISK,0)
        THEN 'Same'
    ELSE 'Different'
END AS CompareResult
FROM VERIFY..BSA_SUB_CUST_FACT v
JOIN BSA_SUB_CUST_FACT b    ON v.CustomerNo = b.CustomerNo
ORDER BY v.CustomerNo;



SELECT a.TS_CUST_ID
FROM
(
    SELECT TS_CUST_ID
    FROM BANCS_SK_CUST_INFO
    WHERE CUST_RE_NO_FLG = '1'

    EXCEPT

    SELECT TS_CUST_ID
    FROM BANCS_SK_CUST_INFO
    WHERE CUST_RE_NO_FLG IN ('2','3')
) a
WHERE NOT EXISTS
(
    SELECT 1
    FROM VERIFY..BSA_SUB_CUST_FACT b
    WHERE b.CustomerNo = a.TS_CUST_ID
);
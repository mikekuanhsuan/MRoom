SELECT DISTINCT a.TS_CUST_ID
FROM BANCS_SK_CUST_INFO a
WHERE a.CUST_RE_NO_FLG IN ('2','3')
AND EXISTS
(
    SELECT 1
    FROM BANCS_SK_CUST_INFO b
    WHERE b.TS_CUST_ID = a.TS_CUST_ID
      AND b.CUST_RE_NO_FLG = '1'
)
AND NOT EXISTS
(
    SELECT 1
    FROM BSA_SUB_CUST_FACT c
    WHERE c.CustomerNo = a.TS_CUST_ID
);
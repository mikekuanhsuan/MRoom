-- 4. 切出需求 / 供給
WITH CTE AS (
    SELECT *,
        ROW_NUMBER() OVER (PARTITION BY col ORDER BY 月份) AS rn
    FROM #Base
),
Demand AS (
    SELECT 
        col,
        月份 AS DemandMonth,
        val AS DemandQty,
        rn,
        SUM(val) OVER (PARTITION BY col ORDER BY rn ROWS UNBOUNDED PRECEDING) AS CumDemand
    FROM CTE
    WHERE val > 0
),
Supply AS (
    SELECT 
        col,
        月份 AS SupplyMonth,
        ABS(val) AS SupplyQty,
        rn,
        SUM(ABS(val)) OVER (PARTITION BY col ORDER BY rn ROWS UNBOUNDED PRECEDING) AS CumSupply
    FROM CTE
    WHERE val < 0
),

-- 5. 做區間交集計算
MatchTable AS (
    SELECT 
        d.col,
        d.DemandMonth,
        s.SupplyMonth,

        -- 分配量 = 區間交集
        CASE 
            WHEN 
                LEAST(d.CumDemand, s.CumSupply) 
                - GREATEST(d.CumDemand - d.DemandQty, s.CumSupply - s.SupplyQty) > 0
            THEN 
                LEAST(d.CumDemand, s.CumSupply) 
                - GREATEST(d.CumDemand - d.DemandQty, s.CumSupply - s.SupplyQty)
            ELSE 0
        END AS AllocQty
    FROM Demand d
    JOIN Supply s
        ON d.col = s.col
)

-- 6. 輸出結果
SELECT 
    DemandMonth AS 需求月份,
    SupplyMonth AS 供給月份,
    AllocQty AS 分配量,
    col AS 列標籤
FROM MatchTable
WHERE AllocQty > 0
ORDER BY col, DemandMonth, SupplyMonth;
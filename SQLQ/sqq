WITH Combined_EXP AS (
    -- 1. LA_INFO
    SELECT 'LA' AS EXP_TYPE, AML_INFO_SEQ, CIF_CUST_INFO_SEQ, TRADE_DATE, NULL AS NEGO_ITEM_SEQ FROM WBS_EXP_LA_INFO
    UNION ALL
    -- 2. LT_INFO
    SELECT 'LT', AML_INFO_SEQ, CIF_CUST_INFO_SEQ, TRADE_DATE, NULL FROM WBS_EXP_LT_INFO
    UNION ALL
    -- 3. NEGO_INFO
    SELECT 'NEGO', AML_INFO_SEQ, CIF_CUST_INFO_SEQ, TRADE_DATE, NULL FROM WBS_EXP_NEGO_INFO
    UNION ALL
    -- 4. OC_INFO
    SELECT 'OC', AML_INFO_SEQ, CIF_CUST_INFO_SEQ, TRADE_DATE, NULL FROM WBS_EXP_OC_INFO
    UNION ALL
    -- 5. RE_NEGO_INFO
    SELECT 'RE_NEGO', AML_INFO_SEQ, CIF_CUST_INFO_SEQ, TRADE_DATE, NULL FROM WBS_EXP_RE_NEGO_INFO
    UNION ALL
    -- 6. NEGO_ITEM (關聯 NEGO_INFO 取得 AML_INFO_SEQ)
    SELECT 'NEGO_ITEM', NEGO.AML_INFO_SEQ, NEGO.CIF_CUST_INFO_SEQ, NEGO.TRADE_DATE, NEGO_ITEM.nego_info_seq
    FROM WBS_EXP_NEGO_INFO NEGO
    INNER JOIN WBS_EXP_NEGO_ITEM NEGO_ITEM ON NEGO.nego_info_seq = NEGO_ITEM.nego_info_seq
    UNION ALL
    -- 7. FA_ITEM (關聯 NEGO_INFO 取得 AML_INFO_SEQ)
    SELECT 'FA_ITEM', NEGO.AML_INFO_SEQ, NEGO.CIF_CUST_INFO_SEQ, NEGO.TRADE_DATE, FA_ITEM.nego_info_seq
    FROM WBS_EXP_NEGO_INFO NEGO
    INNER JOIN WBS_EXP_FA_ITEM FA_ITEM ON NEGO.nego_info_seq = FA_ITEM.nego_info_seq
)
SELECT
    E.EXP_TYPE,            
    '_' + C.CUSTOMER_ID AS CUSTOMER_ID,
    E.TRADE_DATE,
    aml.FUN_CODE,
    F.FUNC_NAME,
    aml.AML_TYPE,
    aml.FLAG,
    aml.CONTENT,
    goodscode.CONTENT AS GOODSCODE,
    merchandise.CONTENT AS MERCHANDISE    
FROM Combined_EXP E
LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WHERE AML_TYPE = 'RED_FLAG') aml
    ON E.AML_INFO_SEQ = aml.AML_INFO_SEQ
LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WHERE AML_TYPE = 'GOODSCODE') goodscode
    ON E.AML_INFO_SEQ = goodscode.AML_INFO_SEQ
LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WHERE AML_TYPE = 'MERCHANDISE') merchandise
    ON E.AML_INFO_SEQ = merchandise.AML_INFO_SEQ
LEFT JOIN WBS_CIF_CUST_INFO C
    ON E.CIF_CUST_INFO_SEQ = C.CIF_CUST_INFO_SEQ
LEFT JOIN WBS_RAA_FUNC_INFO F
    ON aml.FUN_CODE = F.FUNC_CODE
WHERE
    E.TRADE_DATE BETWEEN '20251101' AND '20251130'
    AND aml.FLAG = 'Y'
ORDER BY E.TRADE_DATE, E.EXP_TYPE;



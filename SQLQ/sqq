WITH Combined_list AS (
    -- LOAN CREATION
    SELECT 
        'LOAN' AS SOURCE_TYPE,
        LON_NO AS DOC_NO,
        LON_CCY AS CURRENCY,
        LON_AMT AS AMOUNT,
        CIF_CUST_INFO_SEQ,
        AML_INFO_SEQ,
        TRADE_DATE
    FROM WBS_LON_INFO

    UNION ALL

    -- L/C CREATION
    SELECT 
        'LC_CREATE' AS SOURCE_TYPE,
        LC_NO AS DOC_NO,
        LC_NO_CCY AS CURRENCY,
        LC_NO_AMT AS AMOUNT,
        CIF_CUST_INFO_SEQ,
        AML_INFO_SEQ,
        TRADE_DATE
    FROM WBS_IMP_LC

    UNION ALL

    -- L/C AMENDMENT
    SELECT 
        'LC_AMEND' AS SOURCE_TYPE,
        LC_NO AS DOC_NO,
        LC_NO_CCY AS CURRENCY,
        NEW_AMT AS AMOUNT,
        CIF_CUST_INFO_SEQ,
        AML_INFO_SEQ,
        TRADE_DATE
    FROM WBS_IMP_LC

    UNION ALL

    -- SG/ED CREATION
    SELECT 
        'SGED' AS SOURCE_TYPE,
        SGED_NO AS DOC_NO,
        SGED_CCY AS CURRENCY,
        SGED_AMT AS AMOUNT,
        CIF_CUST_INFO_SEQ,
        AML_INFO_SEQ,
        TRADE_DATE
    FROM WBS_IMP_SGED

    UNION ALL

    -- I/B CREATION
    SELECT 
        'IB' AS SOURCE_TYPE,
        IB_NO AS DOC_NO,
        BILL_CCY AS CURRENCY,
        BILL_AMT1 AS AMOUNT,
        CIF_CUST_INFO_SEQ,
        AML_INFO_SEQ,
        TRADE_DATE
    FROM WBS_IMP_IB

    UNION ALL

    -- I/C CREATION 
    SELECT 
        'IC' AS SOURCE_TYPE,
        IC_NO AS DOC_NO,
        BILL_CCY AS CURRENCY,
        BILL_AMT AS AMOUNT,
        CIF_CUST_INFO_SEQ,
        AML_INFO_SEQ,
        TRADE_DATE
    FROM WBS_IMP_IC

    UNION ALL

    -- L/A CREATION/AMENDMENT
    SELECT 
        'LA' AS SOURCE_TYPE,
        LA_NO AS DOC_NO,
        LC_CCY AS CURRENCY,
        LC_AMT AS AMOUNT,
        CIF_CUST_INFO_SEQ,
        AML_INFO_SEQ,
        TRADE_DATE
    FROM WBS_Exp_La_Info

    UNION ALL

    -- L/T CREATION/amendment
    SELECT 
        'LT' AS SOURCE_TYPE,
        LT_NO AS DOC_NO,
        LC_CCY AS CURRENCY,
        LT_AMT AS AMOUNT,
        CIF_CUST_INFO_SEQ,
        AML_INFO_SEQ,
        TRADE_DATE
    FROM WBS_EXP_LT_INFO

    UNION ALL

    -- NEGO CREATION/AMENDMENT
    SELECT 
        'NEGO' AS SOURCE_TYPE,
        NEGO_NO AS DOC_NO,
        BILL_CCY AS CURRENCY,
        BILL_AMT AS AMOUNT,
        CIF_CUST_INFO_SEQ,
        AML_INFO_SEQ,
        TRADE_DATE
    FROM WBS_EXP_NEGO_INFO

    UNION ALL

    -- RENEGO CREATION
    SELECT 
        'RENEGO' AS SOURCE_TYPE,
        REF_NO AS DOC_NO,
        BILL_CCY AS CURRENCY,
        BILL_AMT AS AMOUNT,
        CIF_CUST_INFO_SEQ,
        AML_INFO_SEQ,
        TRADE_DATE
    FROM WBS_EXP_RE_NEGO_INFO

    UNION ALL

    -- O/C CREATION/AMENDMENT
    SELECT 
        'OC' AS SOURCE_TYPE,
        OC_NO AS DOC_NO,
        BILL_CCY AS CURRENCY,
        BILL_AMT AS AMOUNT,
        CIF_CUST_INFO_SEQ,
        AML_INFO_SEQ,
        TRADE_DATE
    FROM WBS_EXP_OC_INFO
)
SELECT
    E.SOURCE_TYPE,
    E.DOC_NO,
    E.CURRENCY,
    E.AMOUNT,
    E.TRADE_DATE,
    '_' + C.CUSTOMER_ID AS CUSTOMER_ID,
    F.FUNC_NAME,
    aml.FLAG,
    aml.CONTENT,
    goodscode.CONTENT AS GOODSCODE,
    merchandise.CONTENT AS MERCHANDISE,
    TAG44A_CONTENT.CONTENT AS PORT_OF_LOADING,
    TAG44E_CONTENT.CONTENT AS PORT_OF_DISCHARGE,
    TAG44F_CONTENT.CONTENT AS PORT_OF_TRANSSHIPMENT,
    TAG44B_CONTENT.CONTENT AS FINAL_DESTINATION
FROM Combined_list E
LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WHERE AML_TYPE = 'VESSEL_NAME') VESSEL_NAME
    ON E.AML_INFO_SEQ = VESSEL_NAME.AML_INFO_SEQ
LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WHERE AML_TYPE = 'FLAG_VESSEL') FLAG_VESSEL
    ON E.AML_INFO_SEQ = FLAG_VESSEL.AML_INFO_SEQ
LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WHERE AML_TYPE = 'RED_FLAG') aml
    ON E.AML_INFO_SEQ = aml.AML_INFO_SEQ
LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WHERE AML_TYPE = 'REMARK') REMARK
    ON E.AML_INFO_SEQ = REMARK.AML_INFO_SEQ
LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WHERE AML_TYPE = 'GOODSCODE') goodscode
    ON E.AML_INFO_SEQ = goodscode.AML_INFO_SEQ
LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WHERE AML_TYPE = 'MERCHANDISE') merchandise
    ON E.AML_INFO_SEQ = merchandise.AML_INFO_SEQ
LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WHERE AML_TYPE = 'TAG44A_CONTENT') TAG44A_CONTENT
    ON E.AML_INFO_SEQ = TAG44A_CONTENT.AML_INFO_SEQ
LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WHERE AML_TYPE = 'TAG44E_CONTENT') TAG44E_CONTENT
    ON E.AML_INFO_SEQ = TAG44E_CONTENT.AML_INFO_SEQ
LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WHERE AML_TYPE = 'TAG44F_CONTENT') TAG44F_CONTENT
    ON E.AML_INFO_SEQ = TAG44F_CONTENT.AML_INFO_SEQ
LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WHERE AML_TYPE = 'TAG44B_CONTENT') TAG44B_CONTENT
    ON E.AML_INFO_SEQ = TAG44B_CONTENT.AML_INFO_SEQ
LEFT JOIN WBS_CIF_CUST_INFO C
    ON E.CIF_CUST_INFO_SEQ = C.CIF_CUST_INFO_SEQ
LEFT JOIN WBS_RAA_FUNC_INFO F
    ON aml.FUN_CODE = F.FUNC_CODE
WHERE
    E.TRADE_DATE BETWEEN '20251101' AND '20251130'
    AND aml.FLAG = 'Y'
ORDER BY E.TRADE_DATE





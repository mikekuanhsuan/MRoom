WITH Combined_Base AS (
    -- --- 進口部分 (Import) ---
    SELECT 'IMP_IB' AS SRC, AML_INFO_SEQ, CIF_CUST_INFO_SEQ, TRADE_DATE, NULL AS NEGO_ITEM_SEQ FROM WBS_IMP_IB
    UNION ALL
    SELECT 'IMP_BG', AML_INFO_SEQ, CIF_CUST_INFO_SEQ, TRADE_DATE, NULL FROM WBS_IMP_BG
    UNION ALL
    SELECT 'IMP_IC', AML_INFO_SEQ, CIF_CUST_INFO_SEQ, TRADE_DATE, NULL FROM WBS_IMP_IC
    UNION ALL
    SELECT 'IMP_SGED', AML_INFO_SEQ, CIF_CUST_INFO_SEQ, TRADE_DATE, NULL FROM WBS_IMP_SGED
    UNION ALL
    SELECT 'IMP_SGED_LC', LC.AML_INFO_SEQ, LC.CIF_CUST_INFO_SEQ, LC.TRADE_DATE, NULL 
    FROM WBS_IMP_SGED_LC cable INNER JOIN WBS_IMP_LC LC ON cable.LC_NO = LC.LC_NO

    UNION ALL

    -- --- 出口部分 (Export) ---
    SELECT 'EXP_LA', AML_INFO_SEQ, CIF_CUST_INFO_SEQ, TRADE_DATE, NULL FROM WBS_EXP_LA_INFO
    UNION ALL
    SELECT 'EXP_LT', AML_INFO_SEQ, CIF_CUST_INFO_SEQ, TRADE_DATE, NULL FROM WBS_EXP_LT_INFO
    UNION ALL
    SELECT 'EXP_NEGO', AML_INFO_SEQ, CIF_CUST_INFO_SEQ, TRADE_DATE, NULL FROM WBS_EXP_NEGO_INFO
    UNION ALL
    SELECT 'EXP_OC', AML_INFO_SEQ, CIF_CUST_INFO_SEQ, TRADE_DATE, NULL FROM WBS_EXP_OC_INFO
    UNION ALL
    SELECT 'EXP_RE_NEGO', AML_INFO_SEQ, CIF_CUST_INFO_SEQ, TRADE_DATE, NULL FROM WBS_EXP_RE_NEGO_INFO
    
    UNION ALL

    -- --- 出口項目部分 (Items) ---
    SELECT 'EXP_NEGO_ITEM', NEGO.AML_INFO_SEQ, NEGO.CIF_CUST_INFO_SEQ, NEGO.TRADE_DATE, NEGO_ITEM.nego_info_seq
    FROM WBS_EXP_NEGO_INFO NEGO
    INNER JOIN WBS_EXP_NEGO_ITEM NEGO_ITEM ON NEGO.nego_info_seq = NEGO_ITEM.nego_info_seq
    
    UNION ALL

    SELECT 'EXP_FA_ITEM', NEGO.AML_INFO_SEQ, NEGO.CIF_CUST_INFO_SEQ, NEGO.TRADE_DATE, FA_ITEM.nego_info_seq
    FROM WBS_EXP_NEGO_INFO NEGO
    INNER JOIN WBS_EXP_FA_ITEM FA_ITEM ON NEGO.nego_info_seq = FA_ITEM.nego_info_seq
)
SELECT
    base.SRC AS SOURCE_TABLE,  
    '_' + C.CUSTOMER_ID AS CUSTOMER_ID,
    base.TRADE_DATE,
    aml.FUN_CODE,
    F.FUNC_NAME,
    aml.AML_TYPE,
    aml.FLAG,
    aml.CONTENT,
    goodscode.CONTENT AS GOODSCODE,
    merchandise.CONTENT AS MERCHANDISE,
    base.AML_INFO_SEQ,
    base.NEGO_ITEM_SEQ          
FROM Combined_Base base
-- 關聯 AML 詳情
LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WHERE AML_TYPE = 'RED_FLAG') aml
    ON base.AML_INFO_SEQ = aml.AML_INFO_SEQ
LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WHERE AML_TYPE = 'GOODSCODE') goodscode
    ON base.AML_INFO_SEQ = goodscode.AML_INFO_SEQ
LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WHERE AML_TYPE = 'MERCHANDISE') merchandise
    ON base.AML_INFO_SEQ = merchandise.AML_INFO_SEQ
-- 關聯客戶資訊
LEFT JOIN WBS_CIF_CUST_INFO C
    ON base.CIF_CUST_INFO_SEQ = C.CIF_CUST_INFO_SEQ
-- 關聯功能代碼
LEFT JOIN WBS_RAA_FUNC_INFO F
    ON aml.FUN_CODE = F.FUNC_CODE
WHERE
    base.TRADE_DATE BETWEEN '20251101' AND '20251130'
    AND aml.FLAG = 'Y'
ORDER BY base.TRADE_DATE, base.SRC;

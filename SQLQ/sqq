SELECT COUNT(DISTINCT A.ACCT_KEY) AS Missing_Account_Count
FROM LoadTrxn_Migrate_buffer A
 JOIN CIF_Migrate_Mapping_TEMP c ON  a.CIF_KEY = c.SOURCE_CIF_KEY
LEFT JOIN BSADBTW..XREF B       ON RIGHT(REPLICATE('0',25) + A.ACCT_KEY,25) = B.EXTN_REF_NO
WHERE B.EXTN_REF_NO IS NULL  AND A.APPL <> 'LNA';






USE [HKDB]
GO

SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO

CREATE PROCEDURE [dbo].[SP_AMLM005_NEW_REPORT_HK] AS
BEGIN
	-- 關閉計數訊息，優化效能並避免干擾 Informatica 讀取
	SET NOCOUNT ON;

	-- 1. 建立屬於這支新報表的專用全域暫存表
	EXECUTE( N'DROP TABLE IF EXISTS ##AMLM005_NEW_REPORT_HK' );
	
	-- 2. 塞入你的核心自訂報表邏輯
	;WITH Combined_list AS (
		-- LOAN CREATION
		SELECT 'LOAN' AS SOURCE_TYPE, LON_NO AS DOC_NO, LON_CCY AS CURRENCY, LON_AMT AS AMOUNT, CIF_CUST_INFO_SEQ, AML_INFO_SEQ, TRADE_DATE FROM WBS_LON_INFO WITH(NOLOCK)
		UNION ALL
		-- L/C CREATION
		SELECT 'LC_CREATE' AS SOURCE_TYPE, LC_NO AS DOC_NO, LC_NO_CCY AS CURRENCY, LC_NO_AMT AS AMOUNT, CIF_CUST_INFO_SEQ, AML_INFO_SEQ, TRADE_DATE FROM WBS_IMP_LC WITH(NOLOCK)
		UNION ALL
		-- L/C AMENDMENT
		SELECT 'LC_AMEND' AS SOURCE_TYPE, LC_NO AS DOC_NO, LC_NO_CCY AS CURRENCY, NEW_AMT AS AMOUNT, CIF_CUST_INFO_SEQ, AML_INFO_SEQ, TRADE_DATE FROM WBS_IMP_LC WITH(NOLOCK)
		UNION ALL
		-- SG/ED CREATION
		SELECT 'SGED' AS SOURCE_TYPE, SGED_NO AS DOC_NO, SGED_CCY AS CURRENCY, SGED_AMT AS AMOUNT, CIF_CUST_INFO_SEQ, AML_INFO_SEQ, TRADE_DATE FROM WBS_IMP_SGED WITH(NOLOCK)
		UNION ALL
		-- I/B CREATION
		SELECT 'IB' AS SOURCE_TYPE, IB_NO AS DOC_NO, BILL_CCY AS CURRENCY, BILL_AMT1 AS AMOUNT, CIF_CUST_INFO_SEQ, AML_INFO_SEQ, TRADE_DATE FROM WBS_IMP_IB WITH(NOLOCK)
		UNION ALL
		-- I/C CREATION 
		SELECT 'IC' AS SOURCE_TYPE, IC_NO AS DOC_NO, BILL_CCY AS CURRENCY, BILL_AMT AS AMOUNT, CIF_CUST_INFO_SEQ, AML_INFO_SEQ, TRADE_DATE FROM WBS_IMP_IC WITH(NOLOCK)
		UNION ALL
		-- L/A CREATION/AMENDMENT
		SELECT 'LA' AS SOURCE_TYPE, LA_NO AS DOC_NO, LC_CCY AS CURRENCY, LC_AMT AS AMOUNT, CIF_CUST_INFO_SEQ, AML_INFO_SEQ, TRADE_DATE FROM WBS_Exp_La_Info WITH(NOLOCK)
		UNION ALL
		-- L/T CREATION/amendment
		SELECT 'LT' AS SOURCE_TYPE, LT_NO AS DOC_NO, LC_CCY AS CURRENCY, LT_AMT AS AMOUNT, CIF_CUST_INFO_SEQ, AML_INFO_SEQ, TRADE_DATE FROM WBS_EXP_LT_INFO WITH(NOLOCK)
		UNION ALL
		-- NEGO CREATION/AMENDMENT
		SELECT 'NEGO' AS SOURCE_TYPE, NEGO_NO AS DOC_NO, BILL_CCY AS CURRENCY, BILL_AMT AS AMOUNT, CIF_CUST_INFO_SEQ, AML_INFO_SEQ, TRADE_DATE FROM WBS_EXP_NEGO_INFO WITH(NOLOCK)
		UNION ALL
		-- RENEGO CREATION
		SELECT 'RENEGO' AS SOURCE_TYPE, REF_NO AS DOC_NO, BILL_CCY AS CURRENCY, BILL_AMT AS AMOUNT, CIF_CUST_INFO_SEQ, AML_INFO_SEQ, TRADE_DATE FROM WBS_EXP_RE_NEGO_INFO WITH(NOLOCK)
		UNION ALL
		-- O/C CREATION/AMENDMENT
		SELECT 'OC' AS SOURCE_TYPE, OC_NO AS DOC_NO, BILL_CCY AS CURRENCY, BILL_AMT AS AMOUNT, CIF_CUST_INFO_SEQ, AML_INFO_SEQ, TRADE_DATE FROM WBS_EXP_OC_INFO WITH(NOLOCK)
	)
	SELECT
		E.SOURCE_TYPE,
		E.DOC_NO,
		E.CURRENCY,
		-- 格式化金額（去掉科學記號，小數點兩位）
		FORMAT(ROUND(E.AMOUNT * 1.00, 2), '########0.00') AS AMOUNT,
		E.TRADE_DATE,
		IIF(LEN(C.CUSTOMER_ID) > 1, '_' + C.CUSTOMER_ID, '') AS CUSTOMER_ID,
		F.FUNC_NAME,
		aml.FLAG,
		aml.CONTENT AS AML_CONTENT,
		goodscode.CONTENT AS GOODSCODE,
		merchandise.CONTENT AS MERCHANDISE,
		VESSEL_NAME.CONTENT AS VESSEL_NAME,
		FLAG_VESSEL.CONTENT AS FLAG_VESSEL,
		REMARK.CONTENT AS REMARK,
		TAG44A_CONTENT.CONTENT AS PORT_OF_LOADING,
		TAG44E_CONTENT.CONTENT AS PORT_OF_DISCHARGE,
		TAG44F_CONTENT.CONTENT AS PORT_OF_TRANSSHIPMENT,
		TAG44B_CONTENT.CONTENT AS FINAL_DESTINATION
	INTO ##AMLM005_NEW_REPORT_HK
	FROM Combined_list E
	LEFT JOIN WBS_CIF_CUST_INFO C WITH(NOLOCK) ON E.CIF_CUST_INFO_SEQ = C.CIF_CUST_INFO_SEQ
	LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WITH(NOLOCK) WHERE AML_TYPE = 'RED_FLAG') aml ON E.AML_INFO_SEQ = aml.AML_INFO_SEQ
	LEFT JOIN WBS_RAA_FUNC_INFO F WITH(NOLOCK) ON aml.FUN_CODE = F.FUNC_CODE
	LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WITH(NOLOCK) WHERE AML_TYPE = 'GOODSCODE') goodscode ON E.AML_INFO_SEQ = goodscode.AML_INFO_SEQ
	LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WITH(NOLOCK) WHERE AML_TYPE = 'MERCHANDISE') merchandise ON E.AML_INFO_SEQ = merchandise.AML_INFO_SEQ
	LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WITH(NOLOCK) WHERE AML_TYPE = 'VESSEL_NAME') VESSEL_NAME ON E.AML_INFO_SEQ = VESSEL_NAME.AML_INFO_SEQ
	LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WITH(NOLOCK) WHERE AML_TYPE = 'FLAG_VESSEL') FLAG_VESSEL ON E.AML_INFO_SEQ = FLAG_VESSEL.AML_INFO_SEQ
	LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WITH(NOLOCK) WHERE AML_TYPE = 'REMARK') REMARK ON E.AML_INFO_SEQ = REMARK.AML_INFO_SEQ
	LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WITH(NOLOCK) WHERE AML_TYPE = 'TAG44A_CONTENT') TAG44A_CONTENT ON E.AML_INFO_SEQ = TAG44A_CONTENT.AML_INFO_SEQ
	LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WITH(NOLOCK) WHERE AML_TYPE = 'TAG44E_CONTENT') TAG44E_CONTENT ON E.AML_INFO_SEQ = TAG44E_CONTENT.AML_INFO_SEQ
	LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WITH(NOLOCK) WHERE AML_TYPE = 'TAG44F_CONTENT') TAG44F_CONTENT ON E.AML_INFO_SEQ = TAG44F_CONTENT.AML_INFO_SEQ
	LEFT JOIN (SELECT * FROM WBS_AML_DETAIL WITH(NOLOCK) WHERE AML_TYPE = 'TAG44B_CONTENT') TAG44B_CONTENT ON E.AML_INFO_SEQ = TAG44B_CONTENT.AML_INFO_SEQ
	WHERE 1=1
	  AND aml.FLAG = 'Y'
	  -- 動態時間：每個月自動撈取上個月一整個月的資料
	  AND ( (E.TRADE_DATE BETWEEN CONVERT(VARCHAR(8), DATEADD(MONTH, DATEDIFF(MONTH, 0, GETDATE()) - 1, 0), 112) 
	                          AND CONVERT(VARCHAR(8), DATEADD(DAY, -1, DATEADD(MONTH, DATEDIFF(MONTH, 0, GETDATE()), 0)), 112))
	         -- 測試環境相容：如果是在測試機，或者你想手動跑 202511 資料也可以相通
	         OR @@SERVERNAME = 'OBODS_TEST' OR E.TRADE_DATE BETWEEN '20251101' AND '20251130' )
	ORDER BY E.TRADE_DATE;


	-- 3. 自動將上方的 18 個欄位合併成單一字串（符合 Informatica 的單一 COL 設計）
	DECLARE @SQL NVARCHAR(MAX) = N'';
	WITH TBLCOLNME AS (
		SELECT C.OBJECT_ID ,C.NAME FROM TEMPDB.SYS.TABLES T JOIN TEMPDB.SYS.COLUMNS C ON T.OBJECT_ID=C.OBJECT_ID WHERE T.NAME=N'##AMLM005_NEW_REPORT_HK'
	)	
	SELECT DISTINCT
		@SQL = STUFF( (SELECT CONCAT(',"',A.NAME,'"') FROM TBLCOLNME A WHERE  A.OBJECT_ID = B.OBJECT_ID FOR XML PATH ('')) ,1 ,1 ,'')
	FROM TBLCOLNME B

	-- 4. 加上標題、Tab鍵(CHAR(9))串聯，以及報表結尾標記
	SET @SQL = 
		CONCAT( 
			CONCAT( 'SELECT ''', @SQL, ''' AS COL' ) 
			,' UNION ALL '
			,CONCAT( N'SELECT CONCAT(' 
				,N'REPLACE(REPLACE(REPLACE(REPLACE('
				,REPLACE(@SQL, ',', N',CHAR(9),''''''), CHAR(10), ''''''), CHAR(13), ''''''), ''''',''''', '''''，'''''), ''''',''''', REPLACE(REPLACE(REPLACE(REPLACE(')
				,N',CHAR(9),''''''), CHAR(10), ''''''), CHAR(13), ''''''), ''''',''''', '''''，''''')'
				,N') AS COL FROM ##AMLM005_NEW_REPORT_HK ' )
		)
	SET @SQL = CONCAT( @SQL ,N' UNION ALL SELECT '',,,,*** End of Report ***,,,,,,,,,'' ')

	-- 5. 輸出最終結果
	EXECUTE(@SQL); 
END
